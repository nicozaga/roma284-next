const C = CMAP[locale as keyof typeof CMAP] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("milan-events", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  webPageSchema({ name: C.title, description: C.description, url, speakable: ["h1"] }),
  faqPageSchema(C.faq.map((f) => ({ question: f.q, answer: f.a }))),
];
---

<Layout locale={locale} page="milan-events" title={C.title} description={C.description} stickyCtaHref="#book">
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={C.intro} crumbs={crumbs} />

  <ContentSection title={C.venuesTitle} variant="crema">
    <div class="grid gap-5 sm:grid-cols-2">
      {C.venues.map((v) => (
        <article class="rounded-2xl border border-antracite/8 bg-white p-6">
          <h3 class="text-lg text-antracite">{v.t}</h3>
          <p class="mt-2 text-sm leading-relaxed text-grigio">{v.d}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <ContentSection title={C.backTitle} variant="avorio" narrow>
    <p class="leading-relaxed text-grigio" set:html={C.back.replace("23:52", "<strong class='text-antracite'>23:52</strong>")} />
  </ContentSection>

  <ContentSection title={C.faqTitle} variant="crema" narrow>
    <div class="space-y-6">
      {C.faq.map((f) => (
        <div>
          <h3 class="text-lg font-semibold text-antracite">{f.q}</h3>
          <p class="mt-2 leading-relaxed text-grigio">{f.a}</p>
        </div>
      ))}
    </div>
  </ContentSection>

  <BookingWidget locale={locale} title={C.bookTitle} subtitle={C.bookSub} />

  <RelatedLinks locale={locale} items={C.rel as any} />
</Layout>
