---
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";

import type { Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, faqPageSchema } from "@lib/schema";
import { SITE } from "@lib/site";
import { FAQ_FULL } from "@data/faqFull";
import { pick } from "@data/content";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;
const cats = pick(FAQ_FULL, locale);
const flat = cats.flatMap((c) => c.items);

const CMAP = {
  it: {
    title: "Domande frequenti su Roma284 a Piacenza | Roma284",
    description: "Tutte le risposte su Roma284: prenotazione, check-in, servizi, posizione, pagamenti e cancellazione. Wi-Fi 1 Gbit/s, animali benvenuti, 33 min da Milano.",
    eyebrow: "FAQ", h1: "Domande frequenti",
    intro: "Tutto quello che c'è da sapere prima di prenotare. Non trovi la risposta? Scrivici su WhatsApp.",
    crumbHome: "Home", crumb: "FAQ",
    search: "Cerca una domanda…", empty: "Nessun risultato. Prova con altre parole o scrivici su WhatsApp.",
  },
  en: {
    title: "Frequently asked questions about Roma284 | Roma284",
    description: "All the answers about Roma284: booking, check-in, amenities, location, payments and cancellation. 1 Gbit/s Wi-Fi, pets welcome, 33 min from Milan.",
    eyebrow: "FAQ", h1: "Frequently asked questions",
    intro: "Everything you need to know before booking. Can't find the answer? Message us on WhatsApp.",
    crumbHome: "Home", crumb: "FAQ",
    search: "Search a question…", empty: "No results. Try other words or message us on WhatsApp.",
  },
  fr: {
    title: "Foire aux questions sur Roma284 à Plaisance | Roma284",
    description: "Toutes les réponses sur Roma284 : réservation, check-in, services, emplacement, paiements et annulation. Wi-Fi 1 Gbit/s, animaux bienvenus, 33 min de Milan.",
    eyebrow: "FAQ", h1: "Foire aux questions",
    intro: "Tout ce qu'il faut savoir avant de réserver. Vous ne trouvez pas la réponse ? Écrivez-nous sur WhatsApp.",
    crumbHome: "Accueil", crumb: "FAQ",
    search: "Rechercher une question…", empty: "Aucun résultat. Essayez d'autres mots ou écrivez-nous sur WhatsApp.",
  },
  de: {
    title: "Häufig gestellte Fragen zu Roma284 in Piacenza | Roma284",
    description: "Alle Antworten zu Roma284: Buchung, Check-in, Ausstattung, Lage, Zahlungen und Stornierung. WLAN 1 Gbit/s, Haustiere willkommen, 33 Min. von Mailand.",
    eyebrow: "FAQ", h1: "Häufig gestellte Fragen",
    intro: "Alles, was Sie vor der Buchung wissen müssen. Sie finden die Antwort nicht? Schreiben Sie uns auf WhatsApp.",
    crumbHome: "Home", crumb: "FAQ",
    search: "Eine Frage suchen…", empty: "Keine Ergebnisse. Versuchen Sie andere Wörter oder schreiben Sie uns auf WhatsApp.",
  },
  es: {
    title: "Preguntas frecuentes sobre Roma284 en Piacenza | Roma284",
    description: "Todas las respuestas sobre Roma284: reserva, check-in, servicios, ubicación, pagos y cancelación. Wi-Fi 1 Gbit/s, mascotas bienvenidas, 33 min de Milán.",
    eyebrow: "FAQ", h1: "Preguntas frecuentes",
    intro: "Todo lo que hay que saber antes de reservar. ¿No encuentras la respuesta? Escríbenos por WhatsApp.",
    crumbHome: "Inicio", crumb: "FAQ",
    search: "Buscar una pregunta…", empty: "Sin resultados. Prueba con otras palabras o escríbenos por WhatsApp.",
  },
  pt: {
    title: "Perguntas frequentes sobre o Roma284 em Piacenza | Roma284",
    description: "Todas as respostas sobre o Roma284: reserva, check-in, serviços, localização, pagamentos e cancelamento. Wi-Fi 1 Gbit/s, animais bem-vindos, 33 min de Milão.",
    eyebrow: "FAQ", h1: "Perguntas frequentes",
    intro: "Tudo o que há a saber antes de reservar. Não encontra a resposta? Escreva-nos no WhatsApp.",
    crumbHome: "Início", crumb: "FAQ",
    search: "Procurar uma pergunta…", empty: "Sem resultados. Experimente outras palavras ou escreva-nos no WhatsApp.",
  },
};
const C = CMAP[locale as keyof typeof CMAP] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("faq", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  faqPageSchema(flat.map((f) => ({ question: f.q, answer: f.a }))),
];
---

<Layout locale={locale} page="faq" title={C.title} description={C.description}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={C.intro} crumbs={crumbs} />

  <ContentSection variant="crema">
    <label class="relative mx-auto block max-w-xl">
      <span class="sr-only">{C.search}</span>
      <input id="faq-search" type="search" placeholder={C.search}
        class="w-full rounded-full border border-antracite/15 bg-white px-5 py-3 focus:border-terracotta" />
    </label>

    <p id="faq-empty" class="mt-6 hidden text-center text-grigio">{C.empty}</p>

    <div class="mt-10 space-y-12">
      {
        cats.map((cat) => (
          <div class="faq-cat" data-cat>
            <h2 class="font-display text-2xl text-antracite">{cat.category}</h2>
            <div class="mt-4 divide-y divide-antracite/8 overflow-hidden rounded-2xl border border-antracite/8 bg-white">
              {cat.items.map((item) => (
                <details class="faq-item group" data-q={`${item.q} ${item.a}`.toLowerCase()}>
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-antracite">
                    <span class="font-medium">{item.q}</span>
                    <span class="shrink-0 text-terracotta transition group-open:rotate-45">+</span>
                  </summary>
                  <p class="px-5 pb-4 leading-relaxed text-grigio">{item.a}</p>
                </details>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </ContentSection>
</Layout>

<script is:inline>
  const input = document.getElementById("faq-search");
  const items = Array.from(document.querySelectorAll(".faq-item"));
  const cats = Array.from(document.querySelectorAll(".faq-cat"));
  const empty = document.getElementById("faq-empty");
  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    let visible = 0;
    items.forEach((el) => {
      const match = !q || (el.dataset.q || "").includes(q);
      el.style.display = match ? "" : "none";
      if (match) visible++;
    });
    cats.forEach((cat) => {
      const any = cat.querySelectorAll('.faq-item:not([style*="none"])').length;
      cat.style.display = any ? "" : "none";
    });
    empty.classList.toggle("hidden", visible > 0);
  });
</script>
