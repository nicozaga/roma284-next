---
import { Image } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import chiSiamo from "@assets/gallery/chi-siamo.jpg";

import type { Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, organizationSchema } from "@lib/schema";
import { SITE } from "@lib/site";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;

const CMAP = {
  it: {
    title: "Chi siamo: la famiglia dietro Roma284 a Piacenza | Roma284",
    description: "Roma284 è gestito con cura da una famiglia. Ospitalità diretta, attenzione ai dettagli e risposte rapide: Superhost con 4,97/5 su Airbnb e 9,6/10 su Booking.",
    eyebrow: "Chi siamo", h1: "Benvenuti in Casa Roma284",
    crumbHome: "Home", crumb: "Chi siamo",
    imgAlt: "La famiglia che gestisce l'appartamento Roma284 a Piacenza",
    p: [
      "Siamo una gestione familiare specializzata negli affitti brevi nel cuore di Piacenza. La nostra passione è offrire ai nostri ospiti un'esperienza autentica e confortevole, combinando l'atmosfera accogliente di una casa italiana con tutti i servizi moderni.",
      "Il nostro appartamento in Via Roma 284 nasce dalla volontà di condividere con i viaggiatori la bellezza di Piacenza e la comodità di una posizione strategica. Situato a pochi passi dal centro storico e perfettamente collegato con Milano, rappresenta la base ideale per esplorare la città o per viaggi di lavoro.",
      "Ci prendiamo cura di ogni dettaglio: dalla cucina completamente attrezzata al Wi-Fi ultraveloce, dal patio privato al supporto personalizzato 24/7. Il nostro obiettivo è che ogni ospite si senta a casa, con la libertà e l'autonomia di una vera abitazione.",
      "Scegliendo di prenotare direttamente con noi, avrete accesso alle migliori tariffe, flessibilità negli orari e un servizio su misura per le vostre esigenze. Siamo sempre disponibili per consigli su ristoranti, attrazioni e per rendere il vostro soggiorno indimenticabile.",
      `<strong class="text-antracite">Benvenuti nella vostra casa piacentina!</strong>`,
    ],
    rel: [
      { page: "contact", title: "Contatti", text: "Scrivici: email, telefono o WhatsApp." },
      { page: "apartment", title: "L'appartamento", text: "Tutti i dettagli e le foto del bilocale." },
      { page: "faq", title: "Domande frequenti", text: "Tutto quello che c'è da sapere prima di prenotare." },
    ],
  },
  en: {
    title: "About us: the family behind Roma284 in Piacenza | Roma284",
    description: "Roma284 is run with care by a family. Direct hospitality, attention to detail and fast replies: Superhost with 4.97/5 on Airbnb and 9.6/10 on Booking.",
    eyebrow: "About us", h1: "Welcome to Casa Roma284",
    crumbHome: "Home", crumb: "About",
    imgAlt: "The family who run the Roma284 apartment in Piacenza",
    p: [
      "We're a family-run business specialising in short stays in the heart of Piacenza. Our passion is giving our guests an authentic, comfortable experience, combining the welcoming atmosphere of an Italian home with all the modern services.",
      "Our apartment at Via Roma 284 was born from the wish to share with travellers the beauty of Piacenza and the convenience of a strategic location. A short walk from the historic centre and perfectly connected to Milan, it is the ideal base to explore the city or for business trips.",
      "We take care of every detail: from the fully equipped kitchen to the ultra-fast Wi-Fi, from the private patio to personalised 24/7 support. Our goal is for every guest to feel at home, with the freedom and independence of a real house.",
      "By booking directly with us, you get the best rates, flexible timings and a service tailored to your needs. We're always available for tips on restaurants and attractions, and to make your stay unforgettable.",
      `<strong class="text-antracite">Welcome to your home in Piacenza!</strong>`,
    ],
    rel: [
      { page: "contact", title: "Contact", text: "Write to us: email, phone or WhatsApp." },
      { page: "apartment", title: "The apartment", text: "All the details and photos of the flat." },
      { page: "faq", title: "FAQ", text: "Everything to know before booking." },
    ],
  },
  fr: {
    title: "Qui sommes-nous : la famille derrière Roma284 à Plaisance | Roma284",
    description: "Roma284 est géré avec soin par une famille. Hospitalité directe, attention aux détails et réponses rapides : Superhost avec 4,97/5 sur Airbnb et 9,6/10 sur Booking.",
    eyebrow: "Qui sommes-nous", h1: "Bienvenue chez Casa Roma284",
    crumbHome: "Accueil", crumb: "Qui sommes-nous",
    imgAlt: "La famille qui gère l'appartement Roma284 à Plaisance",
    p: [
      "Nous sommes une gestion familiale spécialisée dans les locations de courte durée au cœur de Plaisance. Notre passion est d'offrir à nos hôtes une expérience authentique et confortable, en alliant l'atmosphère chaleureuse d'une maison italienne à tous les services modernes.",
      "Notre appartement au Via Roma 284 est né de l'envie de partager avec les voyageurs la beauté de Plaisance et la commodité d'un emplacement stratégique. À deux pas du centre historique et parfaitement relié à Milan, il représente la base idéale pour explorer la ville ou pour des voyages d'affaires.",
      "Nous prenons soin de chaque détail : de la cuisine entièrement équipée au Wi-Fi ultra-rapide, du patio privé au support personnalisé 24h/24 et 7j/7. Notre objectif est que chaque hôte se sente chez lui, avec la liberté et l'autonomie d'un vrai logement.",
      "En choisissant de réserver directement avec nous, vous bénéficiez des meilleurs tarifs, d'une flexibilité dans les horaires et d'un service sur mesure pour vos besoins. Nous sommes toujours disponibles pour des conseils sur les restaurants, les attractions et pour rendre votre séjour inoubliable.",
      `<strong class="text-antracite">Bienvenue dans votre maison plaisançaise !</strong>`,
    ],
    rel: [
      { page: "contact", title: "Contact", text: "Écrivez-nous : e-mail, téléphone ou WhatsApp." },
      { page: "apartment", title: "L'appartement", text: "Tous les détails et les photos du deux-pièces." },
      { page: "faq", title: "FAQ", text: "Tout ce qu'il faut savoir avant de réserver." },
    ],
  },
  de: {
    title: "Über uns: die Familie hinter Roma284 in Piacenza | Roma284",
    description: "Roma284 wird mit Sorgfalt von einer Familie geführt. Direkte Gastfreundschaft, Liebe zum Detail und schnelle Antworten: Superhost mit 4,97/5 auf Airbnb und 9,6/10 auf Booking.",
    eyebrow: "Über uns", h1: "Willkommen in der Casa Roma284",
    crumbHome: "Home", crumb: "Über uns",
    imgAlt: "Die Familie, die die Wohnung Roma284 in Piacenza führt",
    p: [
      "Wir sind ein Familienbetrieb, der auf Kurzzeitvermietungen im Herzen von Piacenza spezialisiert ist. Unsere Leidenschaft ist es, unseren Gästen ein authentisches und komfortables Erlebnis zu bieten und die einladende Atmosphäre eines italienischen Zuhauses mit allen modernen Annehmlichkeiten zu verbinden.",
      "Unsere Wohnung in der Via Roma 284 entstand aus dem Wunsch, mit Reisenden die Schönheit von Piacenza und den Komfort einer strategischen Lage zu teilen. Wenige Schritte vom historischen Zentrum entfernt und perfekt mit Mailand verbunden, ist sie die ideale Basis, um die Stadt zu erkunden oder für Geschäftsreisen.",
      "Wir kümmern uns um jedes Detail: von der voll ausgestatteten Küche bis zum ultraschnellen WLAN, vom privaten Patio bis zur persönlichen Betreuung rund um die Uhr. Unser Ziel ist es, dass sich jeder Gast wie zu Hause fühlt, mit der Freiheit und Unabhängigkeit eines echten Zuhauses.",
      "Wenn Sie sich für eine Direktbuchung bei uns entscheiden, erhalten Sie die besten Preise, flexible Zeiten und einen auf Ihre Bedürfnisse zugeschnittenen Service. Wir stehen Ihnen jederzeit für Tipps zu Restaurants und Sehenswürdigkeiten zur Verfügung, um Ihren Aufenthalt unvergesslich zu machen.",
      `<strong class="text-antracite">Willkommen in Ihrem Zuhause in Piacenza!</strong>`,
    ],
    rel: [
      { page: "contact", title: "Kontakt", text: "Schreiben Sie uns: E-Mail, Telefon oder WhatsApp." },
      { page: "apartment", title: "Die Wohnung", text: "Alle Details und Fotos der Wohnung." },
      { page: "faq", title: "FAQ", text: "Alles, was Sie vor der Buchung wissen müssen." },
    ],
  },
  es: {
    title: "Quiénes somos: la familia detrás de Roma284 en Piacenza | Roma284",
    description: "Roma284 está gestionado con cuidado por una familia. Hospitalidad directa, atención al detalle y respuestas rápidas: Superhost con 4,97/5 en Airbnb y 9,6/10 en Booking.",
    eyebrow: "Quiénes somos", h1: "Bienvenidos a Casa Roma284",
    crumbHome: "Inicio", crumb: "Quiénes somos",
    imgAlt: "La familia que gestiona el apartamento Roma284 en Piacenza",
    p: [
      "Somos una gestión familiar especializada en alquileres de corta duración en el corazón de Piacenza. Nuestra pasión es ofrecer a nuestros huéspedes una experiencia auténtica y confortable, combinando el ambiente acogedor de una casa italiana con todos los servicios modernos.",
      "Nuestro apartamento en Via Roma 284 nace del deseo de compartir con los viajeros la belleza de Piacenza y la comodidad de una ubicación estratégica. A pocos pasos del centro histórico y perfectamente conectado con Milán, es la base ideal para explorar la ciudad o para viajes de trabajo.",
      "Cuidamos cada detalle: desde la cocina totalmente equipada hasta el Wi-Fi ultrarrápido, desde el patio privado hasta la atención personalizada 24/7. Nuestro objetivo es que cada huésped se sienta como en casa, con la libertad y la autonomía de una verdadera vivienda.",
      "Al elegir reservar directamente con nosotros, tendrás acceso a las mejores tarifas, flexibilidad en los horarios y un servicio a medida de tus necesidades. Estamos siempre disponibles para aconsejarte sobre restaurantes, atracciones y para hacer tu estancia inolvidable.",
      `<strong class="text-antracite">¡Bienvenidos a vuestra casa en Piacenza!</strong>`,
    ],
    rel: [
      { page: "contact", title: "Contacto", text: "Escríbenos: correo electrónico, teléfono o WhatsApp." },
      { page: "apartment", title: "El apartamento", text: "Todos los detalles y las fotos del apartamento." },
      { page: "faq", title: "Preguntas frecuentes", text: "Todo lo que hay que saber antes de reservar." },
    ],
  },
  pt: {
    title: "Quem somos: a família por trás do Roma284 em Piacenza | Roma284",
    description: "O Roma284 é gerido com cuidado por uma família. Hospitalidade direta, atenção ao detalhe e respostas rápidas: Superhost com 4,97/5 no Airbnb e 9,6/10 no Booking.",
    eyebrow: "Quem somos", h1: "Bem-vindos à Casa Roma284",
    crumbHome: "Início", crumb: "Quem somos",
    imgAlt: "A família que gere o apartamento Roma284 em Piacenza",
    p: [
      "Somos uma gestão familiar especializada em arrendamentos de curta duração no coração de Piacenza. A nossa paixão é proporcionar aos hóspedes uma experiência autêntica e confortável, combinando o ambiente acolhedor de uma casa italiana com todos os serviços modernos.",
      "O nosso apartamento na Via Roma 284 nasce da vontade de partilhar com os viajantes a beleza de Piacenza e a comodidade de uma localização estratégica. A poucos passos do centro histórico e perfeitamente ligado a Milão, é a base ideal para explorar a cidade ou para viagens de trabalho.",
      "Cuidamos de cada detalhe: da cozinha totalmente equipada ao Wi-Fi ultrarrápido, do pátio privado ao apoio personalizado 24/7. O nosso objetivo é que cada hóspede se sinta em casa, com a liberdade e a autonomia de uma verdadeira habitação.",
      "Ao optar por reservar diretamente connosco, terá acesso às melhores tarifas, flexibilidade nos horários e um serviço à medida das suas necessidades. Estamos sempre disponíveis para conselhos sobre restaurantes, atrações e para tornar a sua estadia inesquecível.",
      `<strong class="text-antracite">Bem-vindos à vossa casa em Piacenza!</strong>`,
    ],
    rel: [
      { page: "contact", title: "Contactos", text: "Escreva-nos: e-mail, telefone ou WhatsApp." },
      { page: "apartment", title: "O apartamento", text: "Todos os detalhes e fotografias do apartamento." },
      { page: "faq", title: "Perguntas frequentes", text: "Tudo o que há a saber antes de reservar." },
    ],
  },
};
const C = CMAP[locale as keyof typeof CMAP] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("about", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  organizationSchema(),
];
---

<Layout locale={locale} page="about" title={C.title} description={C.description}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} crumbs={crumbs} />

  <ContentSection variant="crema">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <Image
        src={chiSiamo}
        alt={C.imgAlt}
        widths={[480, 720]}
        sizes="(max-width: 1024px) 100vw, 520px"
        format="avif"
        class="rounded-2xl object-cover"
      />
      <div class="space-y-4 leading-relaxed text-grigio">
        {C.p.map((para) => (<p set:html={para} />))}
      </div>
    </div>
  </ContentSection>

  <RelatedLinks locale={locale} items={C.rel as any} />
</Layout>
