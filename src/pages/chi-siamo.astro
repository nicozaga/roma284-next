---
import { Image } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import chiSiamo from "@assets/gallery/chi-siamo.jpg";

import type { Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, organizationSchema } from "@lib/schema";
import { SITE } from "@lib/site";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;

const CMAP = {
  it: {
    title: "Chi siamo: la famiglia dietro Roma284 a Piacenza | Roma284",
    description: "Roma284 è gestito con cura da una famiglia. Ospitalità diretta, attenzione ai dettagli e risposte rapide: Superhost con 4,97/5 su Airbnb e 9,6/10 su Booking.",
    eyebrow: "Chi siamo", h1: "Una casa curata da una famiglia",
    crumbHome: "Home", crumb: "Chi siamo",
    imgAlt: "La famiglia che gestisce l'appartamento Roma284 a Piacenza",
    p: [
      "Roma284 nasce dal desiderio di far vivere Piacenza come la viviamo noi: con i ritmi tranquilli del centro storico e tutti i comfort di casa. Gestiamo l'appartamento in prima persona, con attenzione ai dettagli e disponibilità reale.",
      `Crediamo in un'ospitalità diretta e senza intermediari. Rispondiamo di solito <strong class="text-antracite">entro un'ora</strong>, concordiamo il check-in sui tuoi orari e siamo a disposizione per ogni consiglio, dal ristorante giusto al treno migliore per Milano.`,
      `Questa cura si riflette nelle valutazioni degli ospiti: <strong class="text-antracite">${SITE.rating.airbnb}/5 su Airbnb</strong> e <strong class="text-antracite">${SITE.rating.booking}/10 su Booking</strong>, con lo status di Superhost.`,
      "E sì, gli amici a quattro zampe sono sempre i benvenuti, gratuitamente.",
    ],
    rel: [
      { page: "contact", title: "Contatti", text: "Scrivici: email, telefono o WhatsApp." },
      { page: "apartment", title: "L'appartamento", text: "Tutti i dettagli e le foto del bilocale." },
      { page: "faq", title: "Domande frequenti", text: "Tutto quello che c'è da sapere prima di prenotare." },
    ],
  },
  en: {
    title: "About us: the family behind Roma284 in Piacenza | Roma284",
    description: "Roma284 is run with care by a family. Direct hospitality, attention to detail and fast replies: Superhost with 4.97/5 on Airbnb and 9.6/10 on Booking.",
    eyebrow: "About us", h1: "A home cared for by a family",
    crumbHome: "Home", crumb: "About",
    imgAlt: "The family who run the Roma284 apartment in Piacenza",
    p: [
      "Roma284 was born from the wish to let you experience Piacenza the way we do: with the calm pace of the historic centre and all the comforts of home. We run the apartment ourselves, with attention to detail and genuine availability.",
      `We believe in direct hospitality with no middlemen. We usually reply <strong class="text-antracite">within an hour</strong>, arrange check-in around your schedule and are happy to advise on anything, from the right restaurant to the best train to Milan.`,
      `This care shows in our guests' ratings: <strong class="text-antracite">${SITE.rating.airbnb}/5 on Airbnb</strong> and <strong class="text-antracite">${SITE.rating.booking}/10 on Booking</strong>, with Superhost status.`,
      "And yes, four-legged friends are always welcome, free of charge.",
    ],
    rel: [
      { page: "contact", title: "Contact", text: "Write to us: email, phone or WhatsApp." },
      { page: "apartment", title: "The apartment", text: "All the details and photos of the flat." },
      { page: "faq", title: "FAQ", text: "Everything to know before booking." },
    ],
  },
};
const C = CMAP[locale as "it" | "en"] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("about", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  organizationSchema(),
];
---

<Layout locale={locale} page="about" title={C.title} description={C.description}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} crumbs={crumbs} />

  <ContentSection variant="crema">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <Image
        src={chiSiamo}
        alt={C.imgAlt}
        widths={[480, 720]}
        sizes="(max-width: 1024px) 100vw, 520px"
        format="avif"
        class="rounded-2xl object-cover"
      />
      <div class="space-y-4 leading-relaxed text-grigio">
        {C.p.map((para) => (<p set:html={para} />))}
      </div>
    </div>
  </ContentSection>

  <RelatedLinks locale={locale} items={C.rel as any} />
</Layout>
