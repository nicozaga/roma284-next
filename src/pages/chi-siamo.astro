---
import { Image } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import chiSiamo from "@assets/gallery/chi-siamo.jpg";

import type { Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, organizationSchema } from "@lib/schema";
import { SITE } from "@lib/site";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;

const CMAP = {
  it: {
    title: "Chi siamo: la famiglia dietro Roma284 a Piacenza | Roma284",
    description: "Roma284 è gestito con cura da una famiglia. Ospitalità diretta, attenzione ai dettagli e risposte rapide: Superhost con 4,97/5 su Airbnb e 9,6/10 su Booking.",
    eyebrow: "Chi siamo", h1: "Benvenuti in Casa Roma284",
    crumbHome: "Home", crumb: "Chi siamo",
    imgAlt: "La famiglia che gestisce l'appartamento Roma284 a Piacenza",
    p: [
      "Siamo una gestione familiare specializzata negli affitti brevi nel cuore di Piacenza. La nostra passione è offrire ai nostri ospiti un'esperienza autentica e confortevole, combinando l'atmosfera accogliente di una casa italiana con tutti i servizi moderni.",
      "Il nostro appartamento in Via Roma 284 nasce dalla volontà di condividere con i viaggiatori la bellezza di Piacenza e la comodità di una posizione strategica. Situato a pochi passi dal centro storico e perfettamente collegato con Milano, rappresenta la base ideale per esplorare la città o per viaggi di lavoro.",
      "Ci prendiamo cura di ogni dettaglio: dalla cucina completamente attrezzata al Wi-Fi ultraveloce, dal patio privato al supporto personalizzato 24/7. Il nostro obiettivo è che ogni ospite si senta a casa, con la libertà e l'autonomia di una vera abitazione.",
      "Scegliendo di prenotare direttamente con noi, avrete accesso alle migliori tariffe, flessibilità negli orari e un servizio su misura per le vostre esigenze. Siamo sempre disponibili per consigli su ristoranti, attrazioni e per rendere il vostro soggiorno indimenticabile.",
      `<strong class="text-antracite">Benvenuti nella vostra casa piacentina!</strong>`,
    ],
    rel: [
      { page: "contact", title: "Contatti", text: "Scrivici: email, telefono o WhatsApp." },
      { page: "apartment", title: "L'appartamento", text: "Tutti i dettagli e le foto del bilocale." },
      { page: "faq", title: "Domande frequenti", text: "Tutto quello che c'è da sapere prima di prenotare." },
    ],
  },
  en: {
    title: "About us: the family behind Roma284 in Piacenza | Roma284",
    description: "Roma284 is run with care by a family. Direct hospitality, attention to detail and fast replies: Superhost with 4.97/5 on Airbnb and 9.6/10 on Booking.",
    eyebrow: "About us", h1: "Welcome to Casa Roma284",
    crumbHome: "Home", crumb: "About",
    imgAlt: "The family who run the Roma284 apartment in Piacenza",
    p: [
      "We're a family-run business specialising in short stays in the heart of Piacenza. Our passion is giving our guests an authentic, comfortable experience, combining the welcoming atmosphere of an Italian home with all the modern services.",
      "Our apartment at Via Roma 284 was born from the wish to share with travellers the beauty of Piacenza and the convenience of a strategic location. A short walk from the historic centre and perfectly connected to Milan, it is the ideal base to explore the city or for business trips.",
      "We take care of every detail: from the fully equipped kitchen to the ultra-fast Wi-Fi, from the private patio to personalised 24/7 support. Our goal is for every guest to feel at home, with the freedom and independence of a real house.",
      "By booking directly with us, you get the best rates, flexible timings and a service tailored to your needs. We're always available for tips on restaurants and attractions, and to make your stay unforgettable.",
      `<strong class="text-antracite">Welcome to your home in Piacenza!</strong>`,
    ],
    rel: [
      { page: "contact", title: "Contact", text: "Write to us: email, phone or WhatsApp." },
      { page: "apartment", title: "The apartment", text: "All the details and photos of the flat." },
      { page: "faq", title: "FAQ", text: "Everything to know before booking." },
    ],
  },
};
const C = CMAP[locale as "it" | "en"] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("about", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  organizationSchema(),
];
---

<Layout locale={locale} page="about" title={C.title} description={C.description}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} crumbs={crumbs} />

  <ContentSection variant="crema">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <Image
        src={chiSiamo}
        alt={C.imgAlt}
        widths={[480, 720]}
        sizes="(max-width: 1024px) 100vw, 520px"
        format="avif"
        class="rounded-2xl object-cover"
      />
      <div class="space-y-4 leading-relaxed text-grigio">
        {C.p.map((para) => (<p set:html={para} />))}
      </div>
    </div>
  </ContentSection>

  <RelatedLinks locale={locale} items={C.rel as any} />
</Layout>
