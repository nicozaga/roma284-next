---
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import BookingWidget from "@components/BookingWidget.astro";
import WhyBookDirect from "@components/home/WhyBookDirect.astro";
import ContentSection from "@components/ContentSection.astro";

import type { Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, faqPageSchema } from "@lib/schema";
import { SITE } from "@lib/site";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;

const CMAP = {
  it: {
    title: "Prenota Roma284 a Piacenza — conferma immediata | Roma284",
    description: "Prenota direttamente l'appartamento Roma284 nel centro di Piacenza: conferma immediata, check-in flessibile e contatto diretto con i proprietari. Animali benvenuti.",
    eyebrow: "Prenota", h1: "Prenota direttamente, alle migliori condizioni",
    intro: "Conferma immediata, check-in flessibile e contatto diretto con noi: prenotare sul sito è il modo più semplice per soggiornare a Roma284.",
    crumbHome: "Home", crumb: "Prenota",
    whyTitle: "I vantaggi della prenotazione diretta",
    faqTitle: "Domande sulla prenotazione",
    widgetSub: "Scegli le date: conferma immediata e contatto diretto con noi.",
    faq: [
      { q: "Come ricevo la conferma?", a: "Dopo aver scelto le date ricevi la conferma immediata via email; per qualsiasi dettaglio ci puoi scrivere subito su WhatsApp." },
      { q: "Posso concordare orari di check-in particolari?", a: "Sì. Prenotando in diretta concordiamo check-in e check-out flessibili in base al tuo viaggio." },
      { q: "Quanti ospiti posso prenotare?", a: `L'appartamento ospita fino a ${SITE.stay.maxGuests} persone. Gli animali domestici sono sempre benvenuti, gratuitamente.` },
      { q: "Come pago?", a: "Il pagamento avviene in modo sicuro tramite il sistema di prenotazione. Per esigenze particolari scrivici prima di prenotare." },
    ],
  },
  en: {
    title: "Book Roma284 in Piacenza — instant confirmation | Roma284",
    description: "Book the Roma284 apartment in central Piacenza directly: instant confirmation, flexible check-in and direct contact with the owners. Pets always welcome.",
    eyebrow: "Book", h1: "Book direct, on the best terms",
    intro: "Instant confirmation, flexible check-in and direct contact with us: booking on the site is the easiest way to stay at Roma284.",
    crumbHome: "Home", crumb: "Book",
    whyTitle: "The benefits of booking direct",
    faqTitle: "Booking questions",
    widgetSub: "Pick your dates: instant confirmation and direct contact with us.",
    faq: [
      { q: "How do I get the confirmation?", a: "Once you choose your dates you get instant confirmation by email; for any detail you can message us right away on WhatsApp." },
      { q: "Can I arrange specific check-in times?", a: "Yes. Booking direct, we arrange flexible check-in and check-out around your trip." },
      { q: "How many guests can I book for?", a: `The apartment hosts up to ${SITE.stay.maxGuests} people. Pets are always welcome, free of charge.` },
      { q: "How do I pay?", a: "Payment is handled securely through the booking system. For special needs, write to us before booking." },
    ],
  },
  fr: {
    title: "Réservez Roma284 à Plaisance — confirmation immédiate | Roma284",
    description: "Réservez directement l'appartement Roma284 dans le centre de Plaisance : confirmation immédiate, check-in flexible et contact direct avec les propriétaires. Animaux bienvenus.",
    eyebrow: "Réserver", h1: "Réservez en direct, aux meilleures conditions",
    intro: "Confirmation immédiate, check-in flexible et contact direct avec nous : réserver sur le site est le moyen le plus simple de séjourner à Roma284.",
    crumbHome: "Accueil", crumb: "Réserver",
    whyTitle: "Les avantages de la réservation en direct",
    faqTitle: "Questions sur la réservation",
    widgetSub: "Choisissez vos dates : confirmation immédiate et contact direct avec nous.",
    faq: [
      { q: "Comment recevoir la confirmation ?", a: "Après avoir choisi vos dates, vous recevez la confirmation immédiate par e-mail ; pour tout détail, vous pouvez nous écrire aussitôt sur WhatsApp." },
      { q: "Puis-je convenir d'horaires de check-in particuliers ?", a: "Oui. En réservant en direct, nous convenons d'un check-in et d'un check-out flexibles selon votre voyage." },
      { q: "Pour combien de personnes puis-je réserver ?", a: `L'appartement accueille jusqu'à ${SITE.stay.maxGuests} personnes. Les animaux sont toujours les bienvenus, gratuitement.` },
      { q: "Comment payer ?", a: "Le paiement s'effectue de manière sécurisée via le système de réservation. Pour des besoins particuliers, écrivez-nous avant de réserver." },
    ],
  },
  de: {
    title: "Roma284 in Piacenza buchen — sofortige Bestätigung | Roma284",
    description: "Buchen Sie die Wohnung Roma284 im Zentrum von Piacenza direkt: sofortige Bestätigung, flexibler Check-in und direkter Kontakt mit den Eigentümern. Haustiere willkommen.",
    eyebrow: "Buchen", h1: "Direkt buchen, zu den besten Konditionen",
    intro: "Sofortige Bestätigung, flexibler Check-in und direkter Kontakt mit uns: Die Buchung über die Website ist der einfachste Weg, in Roma284 zu übernachten.",
    crumbHome: "Home", crumb: "Buchen",
    whyTitle: "Die Vorteile der Direktbuchung",
    faqTitle: "Fragen zur Buchung",
    widgetSub: "Wählen Sie Ihre Daten: sofortige Bestätigung und direkter Kontakt mit uns.",
    faq: [
      { q: "Wie erhalte ich die Bestätigung?", a: "Nachdem Sie Ihre Daten gewählt haben, erhalten Sie die Bestätigung sofort per E-Mail; für jedes Detail können Sie uns gleich auf WhatsApp schreiben." },
      { q: "Kann ich besondere Check-in-Zeiten vereinbaren?", a: "Ja. Bei einer Direktbuchung vereinbaren wir flexible Check-in- und Check-out-Zeiten passend zu Ihrer Reise." },
      { q: "Für wie viele Gäste kann ich buchen?", a: `Die Wohnung bietet Platz für bis zu ${SITE.stay.maxGuests} Personen. Haustiere sind jederzeit willkommen, kostenlos.` },
      { q: "Wie bezahle ich?", a: "Die Zahlung erfolgt sicher über das Buchungssystem. Bei besonderen Anliegen schreiben Sie uns vor der Buchung." },
    ],
  },
  es: {
    title: "Reserva Roma284 en Piacenza — confirmación inmediata | Roma284",
    description: "Reserva directamente el apartamento Roma284 en el centro de Piacenza: confirmación inmediata, check-in flexible y contacto directo con los propietarios. Mascotas bienvenidas.",
    eyebrow: "Reservar", h1: "Reserva directamente, en las mejores condiciones",
    intro: "Confirmación inmediata, check-in flexible y contacto directo con nosotros: reservar en la web es la forma más sencilla de alojarte en Roma284.",
    crumbHome: "Inicio", crumb: "Reservar",
    whyTitle: "Las ventajas de la reserva directa",
    faqTitle: "Preguntas sobre la reserva",
    widgetSub: "Elige las fechas: confirmación inmediata y contacto directo con nosotros.",
    faq: [
      { q: "¿Cómo recibo la confirmación?", a: "Tras elegir las fechas recibes la confirmación inmediata por correo electrónico; para cualquier detalle puedes escribirnos enseguida por WhatsApp." },
      { q: "¿Puedo acordar horarios de check-in especiales?", a: "Sí. Reservando directamente acordamos un check-in y un check-out flexibles según tu viaje." },
      { q: "¿Para cuántos huéspedes puedo reservar?", a: `El apartamento aloja hasta ${SITE.stay.maxGuests} personas. Las mascotas son siempre bienvenidas, de forma gratuita.` },
      { q: "¿Cómo pago?", a: "El pago se realiza de forma segura a través del sistema de reservas. Para necesidades especiales, escríbenos antes de reservar." },
    ],
  },
  pt: {
    title: "Reserve o Roma284 em Piacenza — confirmação imediata | Roma284",
    description: "Reserve diretamente o apartamento Roma284 no centro de Piacenza: confirmação imediata, check-in flexível e contacto direto com os proprietários. Animais bem-vindos.",
    eyebrow: "Reservar", h1: "Reserve diretamente, nas melhores condições",
    intro: "Confirmação imediata, check-in flexível e contacto direto connosco: reservar no site é a forma mais simples de ficar no Roma284.",
    crumbHome: "Início", crumb: "Reservar",
    whyTitle: "As vantagens da reserva direta",
    faqTitle: "Perguntas sobre a reserva",
    widgetSub: "Escolha as datas: confirmação imediata e contacto direto connosco.",
    faq: [
      { q: "Como recebo a confirmação?", a: "Depois de escolher as datas recebe a confirmação imediata por e-mail; para qualquer detalhe pode escrever-nos de imediato no WhatsApp." },
      { q: "Posso combinar horários de check-in especiais?", a: "Sim. Ao reservar diretamente, combinamos um check-in e um check-out flexíveis consoante a sua viagem." },
      { q: "Para quantos hóspedes posso reservar?", a: `O apartamento acolhe até ${SITE.stay.maxGuests} pessoas. Os animais de estimação são sempre bem-vindos, gratuitamente.` },
      { q: "Como pago?", a: "O pagamento é feito de forma segura através do sistema de reservas. Para necessidades especiais, escreva-nos antes de reservar." },
    ],
  },
};
const C = CMAP[locale as keyof typeof CMAP] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("book", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  faqPageSchema(C.faq.map((f) => ({ question: f.q, answer: f.a }))),
];
---

<Layout locale={locale} page="book" title={C.title} description={C.description} stickyCta={false}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={C.intro} crumbs={crumbs} />

  <BookingWidget locale={locale} />

  <WhyBookDirect title={C.whyTitle} locale={locale} />

  <ContentSection title={C.faqTitle} variant="avorio" narrow>
    <div class="space-y-6">
      {C.faq.map((f) => (
        <div>
          <h3 class="text-lg font-semibold text-antracite">{f.q}</h3>
          <p class="mt-2 leading-relaxed text-grigio">{f.a}</p>
        </div>
      ))}
    </div>
  </ContentSection>
</Layout>
