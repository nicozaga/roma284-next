---
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import Icon from "@components/Icon.astro";

import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, placeSchema } from "@lib/schema";
import { SITE } from "@lib/site";
import { RESTAURANTS_IT, SUPERMARKETS_IT, SIGHTS_IT } from "@data/neighborhood";

const locale = "it" as const;

const title = "Il quartiere di Roma284: centro storico di Piacenza | Roma284";
const description =
  "Cosa c'è intorno a Roma284 nel centro di Piacenza: Piazza Cavalli e Duomo a 5 minuti a piedi, ristoranti tipici, supermercati e zona pedonale. La guida del quartiere.";

const crumbs = [
  { name: "Home", href: localizedPath("home", locale) },
  { name: "Quartiere", href: localizedPath("area", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  ...SIGHTS_IT.map((s) => placeSchema({ name: s.name, description: s.note })),
];
---

<Layout locale={locale} page="area" title={title} description={description}>
  <JsonLd schema={schema} />

  <PageHero
    eyebrow="Il quartiere"
    title="Nel cuore del centro storico di Piacenza"
    intro="Roma284 si trova in Via Roma 284, nel centro storico di Piacenza. Da qui Piazza Cavalli e il Duomo sono a 5 minuti a piedi e tutto il centro è raggiungibile senza auto: monumenti, ristoranti tipici, caffè e negozi."
    crumbs={crumbs}
  />

  <ContentSection title="Cosa vedere a piedi" variant="crema">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        SIGHTS_IT.map((s) => (
          <article class="rounded-2xl border border-antracite/8 bg-white p-6">
            <h3 class="flex items-center gap-2 text-lg text-antracite">
              <Icon name="pin" class="size-5 text-terracotta" />
              {s.name}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-grigio">{s.note}</p>
          </article>
        ))
      }
    </div>
  </ContentSection>

  <ContentSection title="Dove mangiare" variant="avorio">
    <p class="mb-6 max-w-2xl text-grigio">
      Una selezione di ristoranti, trattorie e pizzerie nel raggio di pochi minuti a piedi, dalla
      cucina piacentina tradizionale alle proposte di pesce e internazionali.
    </p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        RESTAURANTS_IT.map((r) => (
          <div class="rounded-xl border border-antracite/8 bg-white p-5">
            <div class="flex items-baseline justify-between gap-2">
              <h3 class="text-base font-semibold text-antracite">{r.name}</h3>
              <span class="text-xs uppercase tracking-wider text-terracotta">{r.type}</span>
            </div>
            <p class="mt-1.5 text-sm text-grigio">{r.note}</p>
          </div>
        ))
      }
    </div>
  </ContentSection>

  <ContentSection title="Spesa e servizi" variant="crema">
    <div class="grid gap-4 sm:grid-cols-3">
      {
        SUPERMARKETS_IT.map((s) => (
          <div class="rounded-xl bg-avorio p-5">
            <h3 class="font-semibold text-antracite">{s.name}</h3>
            <p class="mt-1 text-sm text-grigio">{s.note}</p>
          </div>
        ))
      }
    </div>
  </ContentSection>

  <RelatedLinks
    locale={locale}
    items={[
      { page: "visit-piacenza", title: "Visitare Piacenza", text: "Itinerari da 1 giorno a un weekend tra arte e cucina." },
      { page: "getting-here", title: "Come arrivare", text: "Tutti i collegamenti da Milano, aeroporti e autostrada." },
      { page: "apartment", title: "L'appartamento", text: "Foto, servizi e dettagli del bilocale Roma284." },
    ]}
  />
</Layout>
