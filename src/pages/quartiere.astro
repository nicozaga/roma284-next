      { page: "visit-piacenza", title: "Visitar Piacenza", text: "Itinerarios de 1 día a un fin de semana, entre arte y gastronomía." },
      { page: "getting-here", title: "Cómo llegar", text: "Todas las conexiones desde Milán, los aeropuertos y la autopista." },
      { page: "apartment", title: "El apartamento", text: "Fotos, servicios y detalles del apartamento Roma284." },
