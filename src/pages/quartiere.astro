---
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import Icon from "@components/Icon.astro";

import type { Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, placeSchema } from "@lib/schema";
import { SITE } from "@lib/site";
import { NEIGHBORHOOD } from "@data/neighborhood";
import { pick } from "@data/content";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;
const n = pick(NEIGHBORHOOD, locale);

const CMAP = {
  it: {
    title: "Il quartiere di Roma284: centro storico di Piacenza | Roma284",
    description: "Cosa c'è intorno a Roma284 nel centro di Piacenza: Piazza Cavalli e Duomo a 5 minuti a piedi, ristoranti tipici, supermercati e zona pedonale. La guida del quartiere.",
    eyebrow: "Il quartiere", h1: "Nel cuore del centro storico di Piacenza",
    intro: "Roma284 si trova in Via Roma 284, nel centro storico di Piacenza. Da qui Piazza Cavalli e il Duomo sono a 5 minuti a piedi e tutto il centro è raggiungibile senza auto: monumenti, ristoranti tipici, caffè e negozi.",
    crumbHome: "Home", crumb: "Quartiere",
    sightsTitle: "Cosa vedere a piedi", eatTitle: "Dove mangiare",
    eatIntro: "Una selezione di ristoranti, trattorie e pizzerie nel raggio di pochi minuti a piedi, dalla cucina piacentina tradizionale alle proposte di pesce e internazionali.",
    shopTitle: "Spesa e servizi", mapsLabel: "Apri in Maps",
    distNote: "Distanze approssimative a piedi da Via Roma 284; il link Maps mostra il percorso esatto.",
    parkTitle: "Parcheggio",
    parkStreet: "Nella via dell'appartamento il parcheggio è su strisce blu: a pagamento di giorno e gratuito dopo le 19. Se preferisci un parcheggio custodito, ne consigliamo uno a soli 300 metri, a 4 € al giorno.",
    parkName: "Urban Center Parking",
    parkAddr: "Stradone Farnese 126",
    parkDist: "~300 m a piedi",
    parkQuery: "Urban Center Parking, Stradone Farnese 126, Piacenza",
    rel: [
      { page: "visit-piacenza", title: "Visitare Piacenza", text: "Itinerari da 1 giorno a un weekend tra arte e cucina." },
      { page: "getting-here", title: "Come arrivare", text: "Tutti i collegamenti da Milano, aeroporti e autostrada." },
      { page: "apartment", title: "L'appartamento", text: "Foto, servizi e dettagli del bilocale Roma284." },
    ],
  },
  en: {
    title: "The Roma284 neighbourhood: historic Piacenza | Roma284",
    description: "What's around Roma284 in central Piacenza: Piazza Cavalli and the Cathedral a 5-minute walk away, traditional restaurants, supermarkets and the pedestrian area.",
    eyebrow: "The area", h1: "In the heart of historic Piacenza",
    intro: "Roma284 is on Via Roma 284, in the historic centre of Piacenza. From here Piazza Cavalli and the Cathedral are a 5-minute walk and the whole centre is reachable without a car: landmarks, traditional restaurants, cafés and shops.",
    crumbHome: "Home", crumb: "Area",
    sightsTitle: "What to see on foot", eatTitle: "Where to eat",
    eatIntro: "A selection of restaurants, trattorias and pizzerias within a few minutes' walk, from traditional Piacenza cuisine to fish and international options.",
    shopTitle: "Shopping and services", mapsLabel: "Open in Maps",
    distNote: "Approximate walking distances from Via Roma 284; the Maps link shows the exact route.",
    parkTitle: "Parking",
    parkStreet: "On the apartment's street, parking is on blue lines: paid during the day and free after 7pm. If you prefer a guarded car park, we recommend one just 300 metres away, at €4 a day.",
    parkName: "Urban Center Parking",
    parkAddr: "Stradone Farnese 126",
    parkDist: "~300 m walk",
    parkQuery: "Urban Center Parking, Stradone Farnese 126, Piacenza",
    rel: [
      { page: "visit-piacenza", title: "Visit Piacenza", text: "Itineraries from 1 day to a weekend, between art and food." },
      { page: "getting-here", title: "Getting here", text: "All connections from Milan, airports and motorway." },
      { page: "apartment", title: "The apartment", text: "Photos, amenities and details of the Roma284 flat." },
    ],
  },
};
const C = CMAP[locale as "it" | "en"] ?? CMAP.it;

const mapsUrl = (q: string) =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}`;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("area", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  ...n.sights.map((s) => placeSchema({ name: s.name, description: s.note })),
];
---

<Layout locale={locale} page="area" title={C.title} description={C.description}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={C.intro} crumbs={crumbs} />

  <ContentSection title={C.sightsTitle} variant="crema">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {n.sights.map((s) => (
        <article class="rounded-2xl border border-antracite/8 bg-white p-6">
          <h3 class="flex items-center gap-2 text-lg text-antracite">
            <Icon name="pin" class="size-5 text-terracotta" />{s.name}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-grigio">{s.note}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <ContentSection title={C.eatTitle} variant="avorio">
    <p class="mb-1 max-w-2xl text-grigio">{C.eatIntro}</p>
    <p class="mb-6 text-xs text-grigio/80">{C.distNote}</p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {n.restaurants.map((r) => (
        <div class="flex flex-col rounded-xl border border-antracite/8 bg-white p-5">
          <div class="flex items-baseline justify-between gap-2">
            <h3 class="text-base font-semibold text-antracite">{r.name}</h3>
            <span class="text-xs uppercase tracking-wider text-terracotta">{r.type}</span>
          </div>
          <p class="mt-1.5 grow text-sm text-grigio">{r.note}</p>
          <p class="mt-3 flex items-center gap-1.5 text-xs text-grigio">
            <Icon name="pin" class="size-3.5 text-salvia" />{r.address} · {r.dist}
          </p>
          <a href={mapsUrl(r.query)} target="_blank" rel="noopener"
            class="mt-1 inline-flex items-center gap-1 text-xs font-medium text-terracotta hover:text-terracotta-dark">
            {C.mapsLabel} →
          </a>
        </div>
      ))}
    </div>
  </ContentSection>

  <ContentSection title={C.shopTitle} variant="crema">
    <div class="grid gap-4 sm:grid-cols-3">
      {n.supermarkets.map((s) => (
        <div class="flex flex-col rounded-xl bg-avorio p-5">
          <h3 class="font-semibold text-antracite">{s.name}</h3>
          <p class="mt-1 grow text-sm text-grigio">{s.note}</p>
          <p class="mt-3 flex items-center gap-1.5 text-xs text-grigio">
            <Icon name="pin" class="size-3.5 text-salvia" />{s.address} · {s.dist}
          </p>
          <a href={mapsUrl(s.query)} target="_blank" rel="noopener"
            class="mt-1 inline-flex items-center gap-1 text-xs font-medium text-terracotta hover:text-terracotta-dark">
            {C.mapsLabel} →
          </a>
        </div>
      ))}
    </div>
  </ContentSection>

  <ContentSection title={C.parkTitle} variant="avorio">
    <div class="grid gap-6 lg:grid-cols-[1.3fr_1fr] lg:items-center">
      <p class="leading-relaxed text-grigio">{C.parkStreet}</p>
      <div class="flex flex-col rounded-xl border border-antracite/8 bg-white p-5">
        <h3 class="font-semibold text-antracite">{C.parkName}</h3>
        <p class="mt-1 flex items-center gap-1.5 text-sm text-grigio">
          <Icon name="pin" class="size-3.5 text-salvia" />{C.parkAddr} · {C.parkDist}
        </p>
        <a href={mapsUrl(C.parkQuery)} target="_blank" rel="noopener"
          class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-terracotta hover:text-terracotta-dark">
          {C.mapsLabel} →
        </a>
      </div>
    </div>
  </ContentSection>

  <RelatedLinks locale={locale} items={C.rel as any} />
</Layout>
