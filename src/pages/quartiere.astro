    crumbHome: "Inicio", crumb: "Barrio",
    sightsTitle: "Qué ver a pie", eatTitle: "Dónde comer",
    eatIntro: "Una selección de restaurantes, trattorias y pizzerías a pocos minutos a pie, desde la cocina tradicional de Piacenza hasta las propuestas de pescado e internacionales.",
    shopTitle: "Compras y servicios", mapsLabel: "Abrir en Maps",
    distNote: "Distancias aproximadas a pie desde Via Roma 284; el enlace de Maps muestra la ruta exacta.",
    parkTitle: "Aparcamiento",
    parkStreet: "En la calle del apartamento el aparcamiento es en línea azul: de pago durante el día y gratuito a partir de las 19. Si prefieres un aparcamiento vigilado, recomendamos uno a solo 300 metros, por 4 € al día.",
    parkName: "Urban Center Parking",
    parkAddr: "Stradone Farnese 126",
    parkDist: "~300 m a pie",
    parkQuery: "Urban Center Parking, Stradone Farnese 126, Piacenza",
