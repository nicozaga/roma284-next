    crumbHome: "Início", crumb: "Bairro",
    sightsTitle: "O que ver a pé", eatTitle: "Onde comer",
    eatIntro: "Uma seleção de restaurantes, trattorias e pizzarias a poucos minutos a pé, da cozinha tradicional de Piacenza às propostas de peixe e internacionais.",
    shopTitle: "Compras e serviços", mapsLabel: "Abrir no Maps",
    distNote: "Distâncias aproximadas a pé a partir da Via Roma 284; o link do Maps mostra o percurso exato.",
    parkTitle: "Estacionamento",
    parkStreet: "Na rua do apartamento o estacionamento é em linhas azuis: pago durante o dia e gratuito a partir das 19h. Se preferir um parque vigiado, recomendamos um a apenas 300 metros, por 4 € por dia.",
    parkName: "Urban Center Parking",
    parkAddr: "Stradone Farnese 126",
    parkDist: "~300 m a pé",
    parkQuery: "Urban Center Parking, Stradone Farnese 126, Piacenza",
    rel: [
      { page: "visit-piacenza", title: "Visitar Piacenza", text: "Itinerários de 1 dia a um fim de semana, entre arte e gastronomia." },
      { page: "getting-here", title: "Como chegar", text: "Todas as ligações de Milão, dos aeroportos e da autoestrada." },
