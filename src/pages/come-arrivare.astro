---
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";
import RelatedLinks from "@components/RelatedLinks.astro";

import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, howToSchema } from "@lib/schema";
import { SITE } from "@lib/site";
import { ROUTES_IT } from "@data/transport";

const locale = "it" as const;

const title = "Come arrivare a Piacenza da Milano e aeroporti | Roma284";
const description =
  "Come raggiungere Roma284 a Piacenza: 33 minuti da Milano Centrale in Frecciarossa, dagli aeroporti di Malpensa, Linate, Bergamo e Bologna, e in auto sull'A1.";

const crumbs = [
  { name: "Home", href: localizedPath("home", locale) },
  { name: "Come arrivare", href: localizedPath("getting-here", locale) },
];
const milano = ROUTES_IT[0];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  howToSchema({
    name: "Come arrivare a Roma284 da Milano Centrale",
    description: milano.summary,
    steps: milano.steps,
  }),
];
---

<Layout locale={locale} page="getting-here" title={title} description={description}>
  <JsonLd schema={schema} />

  <PageHero
    eyebrow="Come arrivare"
    title="Raggiungere Roma284 è semplice"
    intro="Piacenza è a 33 minuti da Milano Centrale in Frecciarossa e ben collegata con i principali aeroporti del Nord Italia. L'appartamento è a 900 metri (9 minuti a piedi) dalla stazione di Piacenza."
    crumbs={crumbs}
  />

  <ContentSection variant="crema">
    <div class="space-y-6">
      {
        ROUTES_IT.map((route) => (
          <article class="rounded-2xl border border-antracite/8 bg-white p-6 lg:p-8">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h2 class="font-display text-2xl text-antracite">{route.from}</h2>
              <span class="rounded-full bg-avorio px-3 py-1 text-sm font-medium text-terracotta">
                {route.duration}
              </span>
            </div>
            <p class="mt-3 leading-relaxed text-grigio">{route.summary}</p>
            <ol class="mt-5 space-y-3">
              {route.steps.map((s, i) => (
                <li class="flex gap-3">
                  <span class="flex size-7 shrink-0 items-center justify-center rounded-full bg-terracotta text-sm font-medium text-white">
                    {i + 1}
                  </span>
                  <div>
                    <p class="font-medium text-antracite">{s.name}</p>
                    <p class="text-sm text-grigio">{s.text}</p>
                  </div>
                </li>
              ))}
            </ol>
          </article>
        ))
      }
    </div>
  </ContentSection>

  <RelatedLinks
    locale={locale}
    items={[
      { page: "stay-near-milan", title: "Dormire vicino Milano", text: "Perché Piacenza è la base intelligente per visitare Milano." },
      { page: "milan-fairs", title: "Fiere di Milano", text: "Come raggiungere la Fiera di Rho da Piacenza." },
      { page: "area", title: "Il quartiere", text: "Cosa trovi intorno all'appartamento, tutto a piedi." },
    ]}
  />
</Layout>
