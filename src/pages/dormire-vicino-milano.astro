<Layout locale={locale} page="stay-near-milan" title={C.title} description={C.description} image="/og/stay-near-milan.jpg" stickyCtaHref="#book">
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={C.intro} crumbs={crumbs} />

  <ContentSection title={C.advTitle} variant="crema">
    <div class="grid gap-5 sm:grid-cols-2">
      {C.advantages.map((a) => (
        <article class="rounded-2xl border border-antracite/8 bg-white p-6">
          <h3 class="flex items-center gap-2 text-lg text-antracite">
            <Icon name="check" class="size-5 text-salvia" />{a.t}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-grigio">{a.d}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <ContentSection title={C.timesTitle} variant="avorio">
    <dl class="speakable divide-y divide-antracite/8 border-y border-antracite/8">
      {C.rows.map(([k, mode, v]) => (
        <div class="flex items-baseline justify-between gap-4 py-3">
          <dt class="text-antracite">{k} {mode && <span class="ml-2 text-sm text-grigio">{mode}</span>}</dt>
          <dd class="font-display text-lg font-medium text-terracotta">{v}</dd>
        </div>
      ))}
    </dl>
    <p class="mt-6 max-w-2xl text-grigio">{C.dayNote}</p>
  </ContentSection>

  <ContentSection title={C.faqTitle} variant="crema" narrow>
    <div class="space-y-6">
      {C.faq.map((f) => (
        <div>
          <h3 class="text-lg font-semibold text-antracite">{f.q}</h3>
          <p class="mt-2 leading-relaxed text-grigio">{f.a}</p>
        </div>
      ))}
    </div>
  </ContentSection>

  <BookingWidget locale={locale} title={C.bookTitle} subtitle={C.bookSub} />

  <RelatedLinks locale={locale} items={C.rel as any} />
</Layout>
