---
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";
import Icon from "@components/Icon.astro";

import type { Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, contactPageSchema } from "@lib/schema";
import { SITE } from "@lib/site";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;

const CMAP = {
  it: {
    title: "Contatti — scrivi a Roma284 a Piacenza | Roma284",
    description: "Contatta Roma284: email viaroma284@gmail.com, telefono e WhatsApp +39 347 810 4634. Rispondiamo di solito entro un'ora. Via Roma 284, Piacenza.",
    eyebrow: "Contatti", h1: "Parliamone direttamente",
    intro: "Hai una domanda o vuoi verificare la disponibilità? Scrivici: rispondiamo di solito entro un'ora.",
    name: "Nome", email: "Email", message: "Messaggio", send: "Invia messaggio",
    crumbHome: "Home", crumb: "Contatti", schemaName: "Contatti — Roma284",
    waMsg: "Ciao, vorrei info su Roma284",
    sending: "Invio in corso…", ok: "Messaggio inviato! Ti rispondiamo al più presto.",
    notReady: 'Modulo non ancora attivo. Scrivici su <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a> o via email.',
    err: 'Errore nell\'invio. Riprova o scrivici su <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a>.',
  },
  en: {
    title: "Contact Roma284 in Piacenza | Roma284",
    description: "Contact Roma284: email viaroma284@gmail.com, phone and WhatsApp +39 347 810 4634. We usually reply within an hour. Via Roma 284, Piacenza, Italy.",
    eyebrow: "Contact", h1: "Let's talk directly",
    intro: "Have a question or want to check availability? Write to us — we usually reply within an hour.",
    name: "Name", email: "Email", message: "Message", send: "Send message",
    crumbHome: "Home", crumb: "Contact", schemaName: "Contact — Roma284",
    waMsg: "Hi, I'd like info about Roma284",
    sending: "Sending…", ok: "Message sent! We'll get back to you shortly.",
    notReady: 'Form not active yet. Message us on <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a> or by email.',
    err: 'Sending error. Please retry or message us on <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a>.',
  },
  fr: {
    title: "Contact — écrivez à Roma284 à Plaisance | Roma284",
    description: "Contactez Roma284 : e-mail viaroma284@gmail.com, téléphone et WhatsApp +39 347 810 4634. Nous répondons généralement en moins d'une heure. Via Roma 284, Plaisance.",
    eyebrow: "Contact", h1: "Parlons-en directement",
    intro: "Vous avez une question ou souhaitez vérifier les disponibilités ? Écrivez-nous : nous répondons généralement en moins d'une heure.",
    name: "Nom", email: "E-mail", message: "Message", send: "Envoyer le message",
    crumbHome: "Accueil", crumb: "Contact", schemaName: "Contact — Roma284",
    waMsg: "Bonjour, je souhaiterais des informations sur Roma284",
    sending: "Envoi en cours…", ok: "Message envoyé ! Nous vous répondons au plus vite.",
    notReady: 'Formulaire pas encore actif. Écrivez-nous sur <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a> ou par e-mail.',
    err: 'Erreur lors de l\'envoi. Réessayez ou écrivez-nous sur <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a>.',
  },
  de: {
    title: "Kontakt — schreiben Sie an Roma284 in Piacenza | Roma284",
    description: "Kontaktieren Sie Roma284: E-Mail viaroma284@gmail.com, Telefon und WhatsApp +39 347 810 4634. Wir antworten meist innerhalb einer Stunde. Via Roma 284, Piacenza.",
    eyebrow: "Kontakt", h1: "Sprechen wir direkt miteinander",
    intro: "Haben Sie eine Frage oder möchten Sie die Verfügbarkeit prüfen? Schreiben Sie uns: Wir antworten meist innerhalb einer Stunde.",
    name: "Name", email: "E-Mail", message: "Nachricht", send: "Nachricht senden",
    crumbHome: "Home", crumb: "Kontakt", schemaName: "Kontakt — Roma284",
    waMsg: "Hallo, ich hätte gerne Infos zu Roma284",
    sending: "Wird gesendet…", ok: "Nachricht gesendet! Wir antworten Ihnen schnellstmöglich.",
    notReady: 'Formular noch nicht aktiv. Schreiben Sie uns auf <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a> oder per E-Mail.',
    err: 'Fehler beim Senden. Bitte erneut versuchen oder schreiben Sie uns auf <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a>.',
  },
  es: {
    title: "Contacto — escribe a Roma284 en Piacenza | Roma284",
    description: "Contacta con Roma284: correo viaroma284@gmail.com, teléfono y WhatsApp +39 347 810 4634. Solemos responder en menos de una hora. Via Roma 284, Piacenza.",
    eyebrow: "Contacto", h1: "Hablemos directamente",
    intro: "¿Tienes una pregunta o quieres comprobar la disponibilidad? Escríbenos: solemos responder en menos de una hora.",
    name: "Nombre", email: "Correo electrónico", message: "Mensaje", send: "Enviar mensaje",
    crumbHome: "Inicio", crumb: "Contacto", schemaName: "Contacto — Roma284",
    waMsg: "Hola, me gustaría información sobre Roma284",
    sending: "Enviando…", ok: "¡Mensaje enviado! Te responderemos lo antes posible.",
    notReady: 'El formulario aún no está activo. Escríbenos por <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a> o por correo electrónico.',
    err: 'Error al enviar. Inténtalo de nuevo o escríbenos por <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a>.',
  },
  pt: {
    title: "Contactos — escreva ao Roma284 em Piacenza | Roma284",
    description: "Contacte o Roma284: e-mail viaroma284@gmail.com, telefone e WhatsApp +39 347 810 4634. Normalmente respondemos em menos de uma hora. Via Roma 284, Piacenza.",
    eyebrow: "Contactos", h1: "Falemos diretamente",
    intro: "Tem uma pergunta ou quer verificar a disponibilidade? Escreva-nos: normalmente respondemos em menos de uma hora.",
    name: "Nome", email: "E-mail", message: "Mensagem", send: "Enviar mensagem",
    crumbHome: "Início", crumb: "Contactos", schemaName: "Contactos — Roma284",
    waMsg: "Olá, gostaria de informações sobre o Roma284",
    sending: "A enviar…", ok: "Mensagem enviada! Responderemos o mais breve possível.",
    notReady: 'Formulário ainda não ativo. Escreva-nos no <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a> ou por e-mail.',
    err: 'Erro ao enviar. Tente novamente ou escreva-nos no <a class="underline" href="$WA" target="_blank" rel="noopener">WhatsApp</a>.',
  },
};
const C = CMAP[locale as keyof typeof CMAP] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("contact", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  contactPageSchema({ name: C.schemaName }),
];
const wa = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(C.waMsg)}`;
const msgs = { sending: C.sending, ok: C.ok, notReady: C.notReady.replace("$WA", wa), err: C.err.replace("$WA", wa) };
---

<Layout locale={locale} page="contact" title={C.title} description={C.description} stickyCta={false}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={C.intro} crumbs={crumbs} />

  <ContentSection variant="crema">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
      <div class="space-y-5">
        <a href={`mailto:${SITE.email}`} class="flex items-center gap-3 text-antracite hover:text-terracotta">
          <span class="flex size-11 items-center justify-center rounded-full bg-avorio text-terracotta"><Icon name="email" class="size-5" /></span>
          <span>{SITE.email}</span>
        </a>
        <a href={`tel:${SITE.phoneIntl}`} class="flex items-center gap-3 text-antracite hover:text-terracotta">
          <span class="flex size-11 items-center justify-center rounded-full bg-avorio text-terracotta"><Icon name="chat" class="size-5" /></span>
          <span>{SITE.phone}</span>
        </a>
        <a href={wa} target="_blank" rel="noopener" data-evt="whatsapp_click" class="flex items-center gap-3 text-antracite hover:text-terracotta">
          <span class="flex size-11 items-center justify-center rounded-full bg-[#25D366]/15 text-[#1faa52]"><Icon name="whatsapp" class="size-5" /></span>
          <span>WhatsApp +39 347 810 4634</span>
        </a>
        <p class="flex items-center gap-3 text-grigio">
          <span class="flex size-11 items-center justify-center rounded-full bg-avorio text-terracotta"><Icon name="pin" class="size-5" /></span>
          <span>Via Roma 284, 29121 Piacenza (PC)</span>
        </p>
      </div>

      <form id="contact-form" class="rounded-2xl border border-antracite/8 bg-white p-6 lg:p-8" novalidate>
        <div class="grid gap-4">
          <label class="block">
            <span class="text-sm font-medium text-antracite">{C.name}</span>
            <input name="name" type="text" required autocomplete="name"
              class="mt-1 w-full rounded-lg border border-antracite/15 bg-crema/50 px-3 py-2.5 outline-none focus:border-terracotta" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-antracite">{C.email}</span>
            <input name="email" type="email" required autocomplete="email"
              class="mt-1 w-full rounded-lg border border-antracite/15 bg-crema/50 px-3 py-2.5 outline-none focus:border-terracotta" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-antracite">{C.message}</span>
            <textarea name="message" rows="5" required
              class="mt-1 w-full rounded-lg border border-antracite/15 bg-crema/50 px-3 py-2.5 outline-none focus:border-terracotta"></textarea>
          </label>
          <input name="company" type="text" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
          <button type="submit"
            class="mt-2 rounded-full bg-terracotta px-6 py-3 font-medium text-white transition hover:bg-terracotta-dark disabled:opacity-60">
            {C.send}
          </button>
          <p id="form-status" role="status" aria-live="polite" class="text-sm"></p>
        </div>
      </form>
    </div>
  </ContentSection>
</Layout>

<script is:inline define:vars={{ msgs }}>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("form-status");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type=submit]");
    const data = Object.fromEntries(new FormData(form).entries());
    btn.disabled = true;
    status.textContent = msgs.sending;
    status.className = "text-sm text-grigio";
    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const out = await res.json().catch(() => ({}));
      if (res.ok && out.ok) {
        status.textContent = msgs.ok;
        status.className = "text-sm text-salvia-dark";
        form.reset();
      } else if (out.error === "email_not_configured") {
        status.innerHTML = msgs.notReady;
        status.className = "text-sm text-terracotta-dark";
      } else {
        throw new Error("send");
      }
    } catch {
      status.innerHTML = msgs.err;
      status.className = "text-sm text-terracotta-dark";
    } finally {
      btn.disabled = false;
    }
  });
</script>
