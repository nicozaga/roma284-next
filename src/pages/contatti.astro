const C = CMAP[locale as keyof typeof CMAP] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("contact", locale) },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  contactPageSchema({ name: C.schemaName }),
];
const wa = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(C.waMsg)}`;
---

<Layout locale={locale} page="contact" title={C.title} description={C.description} stickyCta={false}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={C.intro} crumbs={crumbs} />

  <ContentSection variant="crema">
    <div class="mx-auto max-w-2xl">
      {/* CTA principali: WhatsApp ed email aprono direttamente l'app/client dell'utente */}
      <div class="grid gap-4 sm:grid-cols-2">
        <a href={wa} target="_blank" rel="noopener" data-evt="whatsapp_click"
          class="flex items-center justify-center gap-3 rounded-full bg-[#25D366] px-6 py-4 font-medium text-white transition hover:brightness-95">
          <Icon name="whatsapp" class="size-5" /> WhatsApp
        </a>
        <a href={`mailto:${SITE.email}`} data-evt="email_click"
          class="flex items-center justify-center gap-3 rounded-full bg-terracotta px-6 py-4 font-medium text-white transition hover:bg-terracotta-dark">
          <Icon name="email" class="size-5" /> {C.email}
        </a>
      </div>

      {/* Recapiti completi */}
      <div class="mt-10 space-y-5">
        <a href={`mailto:${SITE.email}`} data-evt="email_click" class="flex items-center gap-3 text-antracite hover:text-terracotta">
          <span class="flex size-11 items-center justify-center rounded-full bg-avorio text-terracotta"><Icon name="email" class="size-5" /></span>
          <span>{SITE.email}</span>
        </a>
        <a href={`tel:${SITE.phoneIntl}`} class="flex items-center gap-3 text-antracite hover:text-terracotta">
          <span class="flex size-11 items-center justify-center rounded-full bg-avorio text-terracotta"><Icon name="chat" class="size-5" /></span>
          <span>{SITE.phone}</span>
        </a>
        <address class="flex items-center gap-3 text-grigio not-italic">
          <span class="flex size-11 items-center justify-center rounded-full bg-avorio text-terracotta"><Icon name="pin" class="size-5" /></span>
          <span>Via Roma 284, 29121 Piacenza (PC), Italia</span>
        </address>
      </div>
    </div>
  </ContentSection>
</Layout>
