---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import RelatedLinks from "@components/RelatedLinks.astro";

import { localizedPath } from "@i18n/utils";
import { articleSchema, breadcrumbSchema } from "@lib/schema";
import { SITE } from "@lib/site";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", (p) => !p.data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const locale = "it" as const;
const blogBase = localizedPath("blog", locale);
const postUrl = `${SITE.url}${blogBase}${post.id}/`;

const crumbs = [
  { name: "Home", href: localizedPath("home", locale) },
  { name: "Blog", href: blogBase },
  { name: post.data.title, href: `${blogBase}${post.id}/` },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  articleSchema({
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: post.data.updatedDate?.toISOString(),
    url: postUrl,
    lang: "it-IT",
  }),
];
const fmt = (d: Date) => d.toLocaleDateString("it-IT", { day: "numeric", month: "long", year: "numeric" });
---

<Layout
  locale={locale}
  page="blog"
  title={`${post.data.title} | Roma284`}
  description={post.data.description}
  ogType="article"
  stickyCta={false}
>
  <JsonLd schema={schema} />

  <article class="mx-auto max-w-3xl px-6 py-12 lg:py-16">
    <Breadcrumbs items={crumbs} />
    <p class="mt-6 text-sm font-medium uppercase tracking-wider text-terracotta">
      {post.data.category}
    </p>
    <h1 class="mt-2 font-display text-4xl text-antracite lg:text-5xl">{post.data.title}</h1>
    <time class="mt-3 block text-sm text-grigio" datetime={post.data.pubDate.toISOString()}>
      {fmt(post.data.pubDate)}
    </time>

    <div class="post-body mt-8">
      <Content />
    </div>
  </article>

  <RelatedLinks
    locale={locale}
    title="Potrebbe interessarti"
    items={[
      { page: "stay-near-milan", title: "Dormire vicino Milano", text: "Perché Piacenza è la base intelligente per Milano." },
      { page: "visit-piacenza", title: "Visitare Piacenza", text: "Itinerari da 1 giorno a un weekend." },
      { page: "book", title: "Prenota", text: "Conferma immediata e contatto diretto." },
    ]}
  />
</Layout>
