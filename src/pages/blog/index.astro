---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";

import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema } from "@lib/schema";
import { SITE } from "@lib/site";

const locale = "it" as const;

const title = "Blog Roma284: guide su Piacenza e Milano | Roma284";
const description =
  "Guide di viaggio, itinerari e consigli pratici su Piacenza e Milano dal blog di Roma284: trasporti, cosa vedere, dove mangiare e come organizzare il soggiorno.";

const crumbs = [
  { name: "Home", href: localizedPath("home", locale) },
  { name: "Blog", href: localizedPath("blog", locale) },
];
const schema = [breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href })))];

const posts = (await getCollection("blog", (p) => !p.data.draft && p.data.lang === "it")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const fmt = (d: Date) => d.toLocaleDateString("it-IT", { day: "numeric", month: "long", year: "numeric" });
---

<Layout locale={locale} page="blog" title={title} description={description} stickyCta={false}>
  <JsonLd schema={schema} />

  <PageHero
    eyebrow="Blog"
    title="Guide e consigli su Piacenza e Milano"
    intro="Itinerari, trasporti e consigli pratici per vivere al meglio il tuo soggiorno."
    crumbs={crumbs}
  />

  <ContentSection variant="crema">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <article class="flex flex-col rounded-2xl border border-antracite/8 bg-white p-6 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-black/5">
            <p class="text-xs font-medium uppercase tracking-wider text-terracotta">
              {post.data.category}
            </p>
            <h2 class="mt-2 font-display text-xl text-antracite">
              <a href={`${localizedPath("blog", locale)}${post.id}/`} class="hover:text-terracotta">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-2 grow text-sm leading-relaxed text-grigio">{post.data.description}</p>
            <time class="mt-4 text-xs text-grigio" datetime={post.data.pubDate.toISOString()}>
              {fmt(post.data.pubDate)}
            </time>
          </article>
        ))
      }
    </div>
  </ContentSection>
</Layout>
