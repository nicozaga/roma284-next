const C = CMAP[locale as keyof typeof CMAP] ?? CMAP.it;

const reviews = REVIEWS_VERIFIED
  ? REVIEWS_IT.map((r) => ({ author: r.author, title: r.title, score: r.score, scale: r.scale, body: r.body }))
  : undefined;

const schema = [
  lodgingBusinessSchema({ lang, reviews }),
  organizationSchema(),
  faqPageSchema(pick(FAQ_HOME, locale).map((f) => ({ question: f.q, answer: f.a }))),
  breadcrumbSchema([{ name: "Home", url: localizedUrl("home", locale) }]),
];
---

<Layout locale={locale} page="home" title={C.title} description={C.description} stickyCtaHref="#book">
  <JsonLd schema={schema} />

  <Hero
    eyebrow={C.eyebrow}
    title={C.h1}
    subtitle={C.sub}
    ctaPrimary={{ label: C.ctaCheck, href: "#book" }}
    ctaSecondary={{ label: C.ctaDiscover, href: "#apartment" }}
    imageAlt={C.heroAlt}
  />

  <TrustStrip locale={locale} />
  <UspCards locale={locale} />
  <GalleryScroll title={C.galleryTitle} subtitle={C.gallerySub} locale={locale} />
  <ApartmentPreview detailsHref={localizedPath("apartment", locale)} ctaLabel={C.seeDetails} locale={locale} />
  <LocationSection ctaHref={localizedPath("getting-here", locale)} ctaLabel={C.gettingHere} locale={locale} />
  <Faq title={C.faqTitle} ctaHref={localizedPath("faq", locale)} ctaLabel={C.allFaq} locale={locale} />
  <Testimonials title={C.reviewsTitle} locale={locale} />
  <LatestPosts locale={locale} />
  <WhyBookDirect title={C.whyTitle} subtitle={C.whySub} locale={locale} />
  <BookingWidget locale={locale} title={C.bookTitle} subtitle={C.bookSub} />
  <FinalCta title={C.finalTitle} text={C.finalText} buttonLabel={C.finalBtn} />
</Layout>
