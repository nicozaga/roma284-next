---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";

import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { localesForPage } from "@i18n/available";
import { breadcrumbSchema } from "@lib/schema";
import { SITE } from "@lib/site";

export const getStaticPaths = (async () => {
  const langs = localesForPage("blog").filter((l) => l !== DEFAULT_LOCALE);
  return langs.map((lang) => ({ params: { lang }, props: { locale: lang } }));
}) satisfies GetStaticPaths;

interface Props { locale: Locale }
const { locale } = Astro.props;

const COPY = {
  en: {
    title: "Roma284 Blog: guides to Piacenza and Milan | Roma284",
    description: "Travel guides, itineraries and practical tips on Piacenza and Milan from the Roma284 blog: transport, what to see, where to eat and how to plan your stay.",
    crumbHome: "Home", crumbBlog: "Blog",
    heroEyebrow: "Blog", heroTitle: "Guides and tips on Piacenza and Milan",
    heroIntro: "Itineraries, transport and practical tips to make the most of your stay.",
    dateLocale: "en-GB",
  },
};
const c = COPY.en; // per ora il blog non-IT è solo EN

const blogBase = localizedPath("blog", locale);
const crumbs = [
  { name: c.crumbHome, href: localizedPath("home", locale) },
  { name: c.crumbBlog, href: blogBase },
];
const schema = [breadcrumbSchema(crumbs.map((x) => ({ name: x.name, url: SITE.url + x.href })))];

const posts = (await getCollection("blog", (p) => !p.data.draft && p.data.lang === locale)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const slugOf = (p: (typeof posts)[number]) => p.data.slug ?? p.id.split("/").pop()!;
const fmt = (d: Date) => d.toLocaleDateString(c.dateLocale, { day: "numeric", month: "long", year: "numeric" });
---

<Layout locale={locale} page="blog" title={c.title} description={c.description} stickyCta={false}>
  <JsonLd schema={schema} />

  <PageHero eyebrow={c.heroEyebrow} title={c.heroTitle} intro={c.heroIntro} crumbs={crumbs} />

  <ContentSection variant="crema">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <article class="flex flex-col rounded-2xl border border-antracite/8 bg-white p-6 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-black/5">
            <p class="text-xs font-medium uppercase tracking-wider text-terracotta">{post.data.category}</p>
            <h2 class="mt-2 font-display text-xl text-antracite">
              <a href={`${blogBase}${slugOf(post)}/`} class="hover:text-terracotta">{post.data.title}</a>
            </h2>
            <p class="mt-2 grow text-sm leading-relaxed text-grigio">{post.data.description}</p>
            <time class="mt-4 text-xs text-grigio" datetime={post.data.pubDate.toISOString()}>
              {fmt(post.data.pubDate)}
            </time>
          </article>
        ))
      }
    </div>
  </ContentSection>
</Layout>
