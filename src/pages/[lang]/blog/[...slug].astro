---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import RelatedLinks from "@components/RelatedLinks.astro";

import { DEFAULT_LOCALE, LOCALE_META, type Locale } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { articleSchema, breadcrumbSchema } from "@lib/schema";
import { SITE } from "@lib/site";

type Alt = { hreflang: string; href: string };

export const getStaticPaths = (async () => {
  const all = await getCollection("blog", (p) => !p.data.draft);
  const slugOf = (p: (typeof all)[number]) => p.data.slug ?? p.id.split("/").pop()!;
  const urlOf = (p: (typeof all)[number]) =>
    `${SITE.url}${localizedPath("blog", p.data.lang as Locale)}${slugOf(p)}/`;

  const paths: any[] = [];
  for (const post of all) {
    const lang = post.data.lang as Locale;
    if (lang === DEFAULT_LOCALE) continue; // l'IT è servito da /blog/[...slug]
    const slug = slugOf(post);
    const group = post.data.translationKey
      ? all.filter((p) => p.data.translationKey === post.data.translationKey)
      : [post];
    const alternates: Alt[] = group.map((p) => ({ hreflang: p.data.lang, href: urlOf(p) }));
    const itv = group.find((p) => p.data.lang === DEFAULT_LOCALE);
    if (itv) alternates.push({ hreflang: "x-default", href: urlOf(itv) });
    paths.push({
      params: { lang, slug },
      props: { locale: lang, post, alternates, canonicalUrl: urlOf(post) },
    });
  }
  return paths;
}) satisfies GetStaticPaths;

interface Props { locale: Locale; post: any; alternates: Alt[]; canonicalUrl: string }
const { locale, post, alternates, canonicalUrl } = Astro.props as Props;
const { Content } = await render(post);

const blogBase = localizedPath("blog", locale);
const slug = post.data.slug ?? post.id.split("/").pop();

const crumbs = [
  { name: "Home", href: localizedPath("home", locale) },
  { name: "Blog", href: blogBase },
  { name: post.data.title, href: `${blogBase}${slug}/` },
];
const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  articleSchema({
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: post.data.updatedDate?.toISOString(),
    image: `${SITE.url}/og/default.jpg`,
    url: canonicalUrl,
    lang: LOCALE_META[locale].htmlLang,
  }),
];
const fmt = (d: Date) => d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
---

<Layout
  locale={locale}
  page="blog"
  title={`${post.data.title} | Roma284`}
  description={post.data.description}
  ogType="article"
  canonicalUrl={canonicalUrl}
  alternates={alternates}
  stickyCta={false}
>
  <JsonLd schema={schema} />

  <article class="mx-auto max-w-3xl px-6 py-12 lg:py-16">
    <Breadcrumbs items={crumbs} />
    <p class="mt-6 text-sm font-medium uppercase tracking-wider text-terracotta">{post.data.category}</p>
    <h1 class="mt-2 font-display text-4xl text-antracite lg:text-5xl">{post.data.title}</h1>
    <time class="mt-3 block text-sm text-grigio" datetime={post.data.pubDate.toISOString()}>
      {fmt(post.data.pubDate)}
    </time>

    <div class="post-body mt-8">
      <Content />
    </div>
  </article>

  <RelatedLinks
    locale={locale}
    title="You might also like"
    items={[
      { page: "stay-near-milan", title: "Stay near Milan", text: "Why Piacenza is the smart base for Milan." },
      { page: "visit-piacenza", title: "Visit Piacenza", text: "Itineraries from one day to a weekend." },
      { page: "book", title: "Book", text: "Instant confirmation and direct contact." },
    ]}
  />
</Layout>
