---
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import ContentSection from "@components/ContentSection.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import BookingWidget from "@components/BookingWidget.astro";

import { localizedPath } from "@i18n/utils";
import { breadcrumbSchema, faqPageSchema, webPageSchema, howToSchema } from "@lib/schema";
import { SITE } from "@lib/site";

const locale = "it" as const;
const url = SITE.url + localizedPath("milan-fairs", locale);

const title = "Fiere di Milano: dormire a Piacenza e raggiungere Rho | Roma284";
const description =
  "Alloggio per le fiere di Milano: da Roma284 raggiungi Fiera Milano Rho in circa un'ora con Frecciarossa + metro M1. Base tranquilla quando gli hotel di Milano sono pieni.";

const crumbs = [
  { name: "Home", href: localizedPath("home", locale) },
  { name: "Fiere Milano", href: localizedPath("milan-fairs", locale) },
];

const fairs = [
  "Salone del Mobile e Fuorisalone",
  "MICAM (calzature)",
  "MIDO (occhialeria)",
  "HOMI e Macef",
  "Host (ospitalità)",
  "EICMA (moto)",
];

const steps = [
  { name: "Frecciarossa per Milano", text: "Dalla stazione di Piacenza prendi la Frecciarossa fino a Milano Centrale in 33 minuti." },
  { name: "Metro M1 per Rho Fiera", text: "A Milano prendi la metro M1 (linea rossa) in direzione Rho Fieramilano: scendi al capolinea, davanti agli ingressi." },
  { name: "Ritorno la sera", text: "La sera fai il percorso inverso: tornare a Piacenza è semplice grazie alla frequenza dei treni." },
];

const faq = [
  { q: "Come arrivo a Fiera Milano Rho da Piacenza?", a: "Prendi la Frecciarossa fino a Milano Centrale (33 minuti) e poi la metro M1 fino a Rho Fieramilano, per un totale di circa un'ora." },
  { q: "Conviene dormire a Piacenza durante le fiere di Milano?", a: "Sì: durante le grandi fiere gli hotel di Milano si riempiono e i prezzi salgono. Piacenza è una base tranquilla e ben collegata, con un intero appartamento a disposizione." },
  { q: "Posso prenotare per più notti durante una fiera?", a: "Sì. Verifica la disponibilità per le tue date nella pagina di prenotazione: la conferma è immediata." },
];

const schema = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
  webPageSchema({ name: title, description, url, speakable: ["h1"] }),
  howToSchema({ name: "Come raggiungere Fiera Milano Rho da Piacenza", description: faq[0].a, steps }),
  faqPageSchema(faq.map((f) => ({ question: f.q, answer: f.a }))),
];
---

<Layout locale={locale} page="milan-fairs" title={title} description={description} stickyCtaHref="#book">
  <JsonLd schema={schema} />

  <PageHero
    eyebrow="Fiere di Milano"
    title="La base comoda per le fiere milanesi"
    intro="Quando gli hotel di Milano sono pieni e cari, Roma284 a Piacenza è la base ideale: raggiungi Fiera Milano Rho in circa un'ora con Frecciarossa e metro M1, e la sera torni in tranquillità."
    crumbs={crumbs}
  />

  <ContentSection title="Come arrivare a Fiera Rho" variant="crema">
    <ol class="space-y-3">
      {
        steps.map((s, i) => (
          <li class="flex gap-3">
            <span class="flex size-7 shrink-0 items-center justify-center rounded-full bg-terracotta text-sm font-medium text-white">{i + 1}</span>
            <div>
              <p class="font-medium text-antracite">{s.name}</p>
              <p class="text-sm text-grigio">{s.text}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </ContentSection>

  <ContentSection title="Le principali fiere milanesi" variant="avorio">
    <p class="mb-5 max-w-2xl text-grigio">
      Milano ospita alcune delle fiere più importanti al mondo. Roma284 è una base comoda per
      raggiungerle, tra cui:
    </p>
    <ul class="flex flex-wrap gap-2">
      {fairs.map((f) => (
        <li class="rounded-full bg-white px-4 py-2 text-sm text-antracite">{f}</li>
      ))}
    </ul>
  </ContentSection>

  <ContentSection title="Domande frequenti" variant="crema" narrow>
    <div class="space-y-6">
      {faq.map((f) => (
        <div>
          <h3 class="text-lg font-semibold text-antracite">{f.q}</h3>
          <p class="mt-2 leading-relaxed text-grigio">{f.a}</p>
        </div>
      ))}
    </div>
  </ContentSection>

  <BookingWidget locale={locale} title="Verifica le date della fiera" subtitle="Conferma immediata, contatto diretto." />

  <RelatedLinks
    locale={locale}
    items={[
      { page: "stay-near-milan", title: "Dormire vicino Milano", text: "Perché Piacenza è la base intelligente per Milano." },
      { page: "getting-here", title: "Come arrivare", text: "Collegamenti da Milano e dagli aeroporti." },
      { page: "smart-working", title: "Smart working", text: "Wi-Fi 1 Gbit/s se unisci lavoro e fiera." },
    ]}
  />
</Layout>
