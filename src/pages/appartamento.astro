---
import Layout from "@layouts/Layout.astro";
import JsonLd from "@components/JsonLd.astro";
import PageHero from "@components/PageHero.astro";
import GalleryScroll from "@components/home/GalleryScroll.astro";
import ContentSection from "@components/ContentSection.astro";
import BookingWidget from "@components/BookingWidget.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import Icon from "@components/Icon.astro";

import type { Locale } from "@i18n/config";
import { LOCALE_META } from "@i18n/config";
import { localizedPath } from "@i18n/utils";
import { apartmentSchema, breadcrumbSchema } from "@lib/schema";
import { AMENITIES } from "@data/amenities";
import { APARTMENT_INTRO, pick } from "@data/content";
import { SITE } from "@lib/site";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;
const lang = LOCALE_META[locale].htmlLang;
const intro = pick(APARTMENT_INTRO, locale);
const amenities = pick(AMENITIES, locale);

const CMAP = {
  it: {
    title: "L'appartamento Roma284 a Piacenza: bilocale 50 m² | Roma284",
    description: "Bilocale di 50 m² al piano terra nel centro di Piacenza: cucina attrezzata, Wi-Fi 1 Gbit/s, patio privato, fino a 4 ospiti, animali benvenuti. Tutti i dettagli.",
    eyebrow: "L'appartamento", h1: "Un bilocale elegante nel cuore di Piacenza",
    crumbHome: "Home", crumb: "Appartamento",
    galleryTitle: "Le immagini dell'appartamento",
    specialTitle: "Cosa rende speciale Roma284",
    amenTitle: "Tutti i servizi",
    bookTitle: "Disponibilità e prenotazione", bookSub: "Scegli le date: conferma immediata e contatto diretto con noi.",
    seeDetails: "Vedi tutti i dettagli",
    specs: [
      { k: "Superficie", v: `${SITE.stay.sizeSqm} m²` }, { k: "Composizione", v: "1 camera + soggiorno" },
      { k: "Bagni", v: "1" }, { k: "Ospiti", v: `fino a ${SITE.stay.maxGuests}` },
      { k: "Piano", v: "Piano terra, no scale" }, { k: "Animali", v: "Benvenuti, gratis" },
    ],
    blocks: [
      ["Zona notte e soggiorno.", "La camera ha un letto matrimoniale (152×203) separabile in due singoli su richiesta, con topper in memory foam. In soggiorno due comode poltrone letto singolo permettono di ospitare fino a 4 persone."],
      ["Cucina open space.", "È il cuore della casa: piano a induzione a 4 fuochi, forno combinato ventilato e microonde, lavastoviglie, frigorifero con freezer e macchina caffè Nespresso con cialde omaggio."],
      ["Comfort e tecnologia.", "Climatizzazione caldo/freddo, riscaldamento autonomo, Wi-Fi in fibra da 1 Gbit/s ideale per lo smart working e Smart TV da 55\" con Netflix e YouTube."],
      ["Patio privato.", "Uno spazio esterno arredato sul tranquillo cortile interno, perfetto per la colazione al sole o un aperitivo la sera — comodo anche per chi viaggia con il cane."],
    ],
    rel: [
      { page: "area", title: "Il quartiere", text: "Cosa c'è intorno a Roma284: piazze, monumenti e ristoranti a piedi." },
      { page: "getting-here", title: "Come arrivare", text: "Da Milano, dagli aeroporti e in auto: tutti i collegamenti." },
      { page: "smart-working", title: "Smart working", text: "Wi-Fi 1 Gbit/s e postazione dedicata per lavorare da remoto." },
    ],
  },
  en: {
    title: "The Roma284 apartment in Piacenza: 50 m² one-bed | Roma284",
    description: "50 m² ground-floor one-bedroom apartment in central Piacenza: equipped kitchen, 1 Gbit/s Wi-Fi, private patio, up to 4 guests, pets welcome. All the details.",
    eyebrow: "The apartment", h1: "An elegant one-bedroom in the heart of Piacenza",
    crumbHome: "Home", crumb: "The apartment",
    galleryTitle: "Photos of the apartment",
    specialTitle: "What makes Roma284 special",
    amenTitle: "All amenities",
    bookTitle: "Availability and booking", bookSub: "Pick your dates: instant confirmation and direct contact with us.",
    seeDetails: "See all details",
    specs: [
      { k: "Size", v: `${SITE.stay.sizeSqm} m²` }, { k: "Layout", v: "1 bedroom + living room" },
      { k: "Bathrooms", v: "1" }, { k: "Guests", v: `up to ${SITE.stay.maxGuests}` },
      { k: "Floor", v: "Ground floor, no stairs" }, { k: "Pets", v: "Welcome, free" },
    ],
    blocks: [
      ["Sleeping and living area.", "The bedroom has a double bed (152×203) splittable into two singles on request, with a memory-foam topper. In the living room, two comfortable single sofa beds host up to 4 people."],
      ["Open-plan kitchen.", "It is the heart of the home: 4-ring induction hob, fan combi oven with microwave, dishwasher, fridge with freezer and a Nespresso coffee machine with complimentary capsules."],
      ["Comfort and technology.", "Hot/cold air conditioning, independent heating, 1 Gbit/s fibre Wi-Fi ideal for remote work and a 55\" Smart TV with Netflix and YouTube."],
      ["Private patio.", "A furnished outdoor space on the quiet inner courtyard, perfect for breakfast in the sun or an evening aperitif — handy for those travelling with a dog too."],
    ],
    rel: [
      { page: "area", title: "The area", text: "What's around Roma284: squares, landmarks and restaurants on foot." },
      { page: "getting-here", title: "Getting here", text: "From Milan, the airports and by car: all the connections." },
      { page: "smart-working", title: "Smart working", text: "1 Gbit/s Wi-Fi and a dedicated workspace for remote work." },
    ],
  },
};
const C = CMAP[locale as "it" | "en"] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("apartment", locale) },
];
const schema = [
  apartmentSchema({ name: "Roma284", description: intro, lang }),
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
];
---

<Layout locale={locale} page="apartment" title={C.title} description={C.description} stickyCtaHref="#book">
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={intro} crumbs={crumbs} />

  <GalleryScroll title={C.galleryTitle} locale={locale} />

  <ContentSection title={C.specialTitle} variant="crema">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr]">
      <div class="space-y-4 leading-relaxed text-grigio">
        {C.blocks.map(([b, t]) => (
          <p><strong class="text-antracite">{b}</strong> {t}</p>
        ))}
      </div>

      <dl class="grid h-fit grid-cols-2 gap-px overflow-hidden rounded-2xl border border-antracite/8 bg-antracite/8">
        {C.specs.map((s) => (
          <div class="bg-white p-4">
            <dt class="text-xs uppercase tracking-wider text-grigio">{s.k}</dt>
            <dd class="mt-1 font-display text-lg text-antracite">{s.v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </ContentSection>

  <ContentSection title={C.amenTitle} variant="avorio">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        amenities.map((group) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-antracite">{group.title}</h3>
            <ul class="mt-3 space-y-1.5 text-sm text-grigio">
              {group.items.map((item) => (
                <li class="flex items-start gap-2">
                  <Icon name="check" class="mt-0.5 size-4 shrink-0 text-salvia" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </ContentSection>

  <BookingWidget locale={locale} title={C.bookTitle} subtitle={C.bookSub} />

  <RelatedLinks locale={locale} items={C.rel as any} />
</Layout>
