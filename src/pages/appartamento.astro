      { k: "Área", v: `${SITE.stay.sizeSqm} m²` }, { k: "Composição", v: "1 quarto + sala" },
      { k: "Casas de banho", v: "1" }, { k: "Hóspedes", v: `até ${SITE.stay.maxGuests}` },
      { k: "Piso", v: "Rés-do-chão, sem escadas" }, { k: "Animais", v: "Bem-vindos, gratuito" },
