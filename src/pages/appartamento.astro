    eyebrow: "O apartamento", h1: "Um elegante T1 no coração de Piacenza",
    crumbHome: "Início", crumb: "Apartamento",
    galleryTitle: "As imagens do apartamento",
    specialTitle: "O que torna o Roma284 especial",
    amenTitle: "Todos os serviços",
    bookTitle: "Disponibilidade e reserva", bookSub: "Escolha as datas: confirmação imediata e contacto direto connosco.",
