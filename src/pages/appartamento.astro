    bookTitle: "Verfügbarkeit und Buchung", bookSub: "Wählen Sie Ihre Daten: sofortige Bestätigung und direkter Kontakt mit uns.",
    seeDetails: "Alle Details ansehen",
    specs: [
      { k: "Fläche", v: `${SITE.stay.sizeSqm} m²` }, { k: "Aufteilung", v: "1 Schlafzimmer + Wohnzimmer" },
