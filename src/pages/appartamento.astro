      { k: "Etage", v: "Erdgeschoss, keine Treppen" }, { k: "Haustiere", v: "Willkommen, kostenlos" },
    ],
    blocks: [
      ["Schlaf- und Wohnbereich.", "Das Schlafzimmer hat ein Doppelbett (152×203), auf Wunsch in zwei Einzelbetten teilbar, mit Memory-Foam-Topper. Im Wohnzimmer bieten zwei bequeme Einzel-Schlafsessel Platz für bis zu 4 Personen."],
