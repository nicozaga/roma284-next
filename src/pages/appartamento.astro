    blocks: [
      ["Zona de dormir e sala.", "O quarto tem uma cama de casal (152×203) separável em duas individuais a pedido, com topper em espuma viscoelástica. Na sala, dois cómodos cadeirões-cama individuais permitem acolher até 4 pessoas."],
      ["Cozinha aberta.", "É o coração da casa: placa de indução de 4 zonas, forno combinado ventilado e micro-ondas, máquina de lavar loiça, frigorífico com congelador e máquina de café Nespresso com cápsulas oferecidas."],
      ["Conforto e tecnologia.", "Climatização quente/frio, aquecimento autónomo, Wi-Fi de fibra de 1 Gbit/s ideal para o teletrabalho e Smart TV de 55\" com Netflix e YouTube."],
      ["Uma casa de banho de alto nível.", "Uma casa de banho cuidada com uma ampla base de duche walk-in. Disponibilizamos champô, gel de banho e sabonete para as mãos, além de toalhas e um kit de cortesia."],
      ["Pátio privado.", "Um espaço exterior mobilado no tranquilo pátio interior, perfeito para o pequeno-almoço ao sol ou um aperitivo à noite — prático também para quem viaja com cão."],
    ],
    rel: [
      { page: "area", title: "O bairro", text: "O que há à volta do Roma284: praças, monumentos e restaurantes a pé." },
      { page: "getting-here", title: "Como chegar", text: "De Milão, dos aeroportos e de carro: todas as ligações." },
      { page: "smart-working", title: "Teletrabalho", text: "Wi-Fi 1 Gbit/s e posto de trabalho dedicado para trabalhar à distância." },
    ],
  },
};
const C = CMAP[locale as keyof typeof CMAP] ?? CMAP.it;

const crumbs = [
  { name: C.crumbHome, href: localizedPath("home", locale) },
  { name: C.crumb, href: localizedPath("apartment", locale) },
];
const schema = [
  apartmentSchema({ name: "Roma284", description: intro, lang }),
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: SITE.url + c.href }))),
];
---

<Layout locale={locale} page="apartment" title={C.title} description={C.description} stickyCtaHref="#book">
  <JsonLd schema={schema} />

  <PageHero eyebrow={C.eyebrow} title={C.h1} intro={intro} crumbs={crumbs} />

  <GalleryScroll title={C.galleryTitle} locale={locale} />

  <ContentSection title={C.specialTitle} variant="crema">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr]">
      <div class="space-y-4 leading-relaxed text-grigio">
        {C.blocks.map(([b, t]) => (
          <p><strong class="text-antracite">{b}</strong> {t}</p>
        ))}
      </div>

      <dl class="grid h-fit grid-cols-2 gap-px overflow-hidden rounded-2xl border border-antracite/8 bg-antracite/8">
        {C.specs.map((s) => (
          <div class="bg-white p-4">
            <dt class="text-xs uppercase tracking-wider text-grigio">{s.k}</dt>
            <dd class="mt-1 font-display text-lg text-antracite">{s.v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </ContentSection>

  <ContentSection title={C.amenTitle} variant="avorio">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        amenities.map((group) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-antracite">{group.title}</h3>
            <ul class="mt-3 space-y-1.5 text-sm text-grigio">
              {group.items.map((item) => (
                <li class="flex items-start gap-2">
                  <Icon name="check" class="mt-0.5 size-4 shrink-0 text-salvia" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </ContentSection>

  <BookingWidget locale={locale} title={C.bookTitle} subtitle={C.bookSub} />

  <RelatedLinks locale={locale} items={C.rel as any} />
</Layout>
