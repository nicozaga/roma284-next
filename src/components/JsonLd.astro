---
/**
 * Componente riusabile per dati strutturati schema.org.
 * Accetta uno o più nodi e li racchiude in un @graph con @context.
 * Uso: <JsonLd schema={[organizationSchema(), faqPageSchema(items)]} />
 */
interface Props {
  schema: Record<string, unknown> | Record<string, unknown>[];
}
const { schema } = Astro.props;
const nodes = Array.isArray(schema) ? schema : [schema];
const json = {
  "@context": "https://schema.org",
  "@graph": nodes,
};
---
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(json)}
/>
