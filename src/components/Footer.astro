---
import { LOCALE_META, type Locale } from "@i18n/config";
import { localizedPath, switchLocale, bestPath } from "@i18n/utils";
import { localesForPage, pageHasLocale } from "@i18n/available";
import { useTranslations } from "@i18n/ui";
import type { PageKey } from "@i18n/slugs";
import { SITE } from "@lib/site";
import Icon from "./Icon.astro";

interface Props {
  locale: Locale;
  page: PageKey;
}
const { locale, page } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();

// Pagine legali: solo IT + EN (le altre lingue ricadono sull'IT).
const legalHref = locale === "en" ? "/en/privacy-policy" : "/privacy-policy";
const legalLabel = locale === "en" ? "Privacy & Terms" : "Privacy e Termini";

const cols: { key: PageKey; label: string }[][] = [
  [
    { key: "apartment", label: t("nav.apartment") },
    { key: "area", label: t("nav.area") },
    { key: "getting-here", label: t("nav.getting_here") },
    { key: "visit-piacenza", label: t("nav.visit") },
  ],
  [
    { key: "stay-near-milan", label: t("nav.stay_near_milan") },
    { key: "smart-working", label: t("nav.smart_working") },
    { key: "a1-stopover", label: t("nav.a1_stopover") },
    { key: "fairs", label: t("nav.fairs") },
    { key: "milan-events", label: t("nav.milan_events") },
  ],
  [
    { key: "about", label: t("nav.about") },
    { key: "contact", label: t("nav.contact") },
    { key: "faq", label: t("nav.faq") },
    { key: "blog", label: t("nav.blog") },
  ],
];
---

<footer class="mt-24 bg-antracite text-crema/80">
  <div class="mx-auto max-w-(--breakpoint-xl) px-6 py-16">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <p class="font-display text-2xl font-semibold text-white">
          Roma<span class="text-terracotta-light">284</span>
        </p>
        <p class="mt-3 max-w-xs text-sm leading-relaxed">{t("footer.tagline")}</p>
        <div class="mt-5 space-y-2 text-sm">
          <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 hover:text-white">
            <Icon name="email" class="size-4" />{SITE.email}
          </a>
          <a href={`tel:${SITE.phoneIntl}`} class="flex items-center gap-2 hover:text-white">
            <Icon name="chat" class="size-4" />{SITE.phone}
          </a>
          <p class="flex items-center gap-2">
            <Icon name="pin" class="size-4" />Via Roma 284, 29121 Piacenza
          </p>
        </div>
      </div>

      {
        cols.map((col) => (
          <nav class="text-sm">
            <ul class="space-y-2.5">
              {col.filter((l) => pageHasLocale(l.key, locale)).map((l) => (
                <li>
                  <a href={bestPath(l.key, locale)} class="hover:text-white">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    {/* Lingue */}
    <div class="mt-12 border-t border-white/10 pt-8">
      <p class="mb-3 text-xs uppercase tracking-wider text-crema/50">
        {t("common.language")}
      </p>
      <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
        {
          localesForPage(page).map((loc) => (
            <li>
              <a
                href={switchLocale(page, loc)}
                hreflang={LOCALE_META[loc].htmlLang}
                class:list={["hover:text-white", loc === locale && "text-white font-medium"]}
              >
                {LOCALE_META[loc].label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div
      class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 text-xs text-crema/50 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} Roma284. {t("footer.rights")}</p>
      <div class="flex flex-wrap gap-4">
        <a href={SITE.social.airbnb} rel="noopener" target="_blank" class="hover:text-white">Airbnb</a>
        <a href={SITE.social.booking} rel="noopener" target="_blank" class="hover:text-white">Booking</a>
        <a href={SITE.social.maps} rel="noopener" target="_blank" class="hover:text-white">Google Maps</a>
        <a href={legalHref} class="hover:text-white">{legalLabel}</a>
        <a href="/sitemap-index.xml" class="hover:text-white">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
