---
import { LOCALE_META, type Locale } from "@i18n/config";
import { localizedPath, switchLocale, bestPath } from "@i18n/utils";
import { localesForPage } from "@i18n/available";
import { useTranslations } from "@i18n/ui";
import type { PageKey } from "@i18n/slugs";
import Icon from "./Icon.astro";

interface Props {
  locale: Locale;
  page: PageKey;
}
const { locale, page } = Astro.props;
const t = useTranslations(locale);

const nav: { key: PageKey; label: string }[] = [
  { key: "apartment", label: t("nav.apartment") },
  { key: "area", label: t("nav.area") },
  { key: "getting-here", label: t("nav.getting_here") },
  { key: "visit-piacenza", label: t("nav.visit") },
  { key: "about", label: t("nav.about") },
  { key: "faq", label: t("nav.faq") },
];
const home = localizedPath("home", locale);
const bookHref = localizedPath("book", locale);
const switchLocales = localesForPage(page);
---

<header
  class="sticky top-0 z-40 border-b border-antracite/8 bg-crema/85 backdrop-blur-md"
>
  <div
    class="mx-auto flex h-16 max-w-(--breakpoint-xl) items-center justify-between gap-4 px-6"
  >
    <a href={home} class="font-display text-xl font-semibold text-antracite">
      Roma<span class="text-terracotta">284</span>
    </a>

    <nav aria-label="Principale" class="hidden items-center gap-7 lg:flex">
      {
        nav.map((item) => (
          <a
            href={localizedPath(item.key, locale)}
            class="text-sm text-grigio transition hover:text-terracotta"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      {/* Language switcher — native, zero JS. Solo lingue disponibili per la pagina. */}
      {switchLocales.length > 1 && (
      <details class="group relative hidden sm:block">
        <summary
          class="flex cursor-pointer list-none items-center gap-1 rounded-full px-3 py-2 text-sm text-grigio transition hover:text-terracotta"
        >
          <Icon name="globe" class="size-4" />
          <span class="uppercase">{locale === "zh-cn" ? "zh" : locale}</span>
        </summary>
        <ul
          class="absolute right-0 mt-2 grid max-h-72 w-44 grid-cols-1 gap-0.5 overflow-auto rounded-xl border border-antracite/10 bg-white p-2 shadow-xl"
        >
          {
            switchLocales.map((loc) => (
              <li>
                <a
                  href={switchLocale(page, loc)}
                  hreflang={LOCALE_META[loc].htmlLang}
                  class:list={[
                    "block rounded-lg px-3 py-1.5 text-sm transition hover:bg-avorio",
                    loc === locale ? "font-semibold text-terracotta" : "text-antracite",
                  ]}
                >
                  {LOCALE_META[loc].label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      )}

      <a
        href={bookHref}
        class="hidden rounded-full bg-terracotta px-5 py-2 text-sm font-medium text-white transition hover:bg-terracotta-dark sm:inline-block"
      >
        {t("cta.check_availability")}
      </a>

      {/* Mobile menu — native details */}
      <details class="lg:hidden">
        <summary
          class="flex cursor-pointer list-none items-center rounded-full p-2 text-antracite"
          aria-label={t("common.menu")}
        >
          <Icon name="menu" class="size-6" />
        </summary>
        <div
          class="absolute left-0 right-0 top-16 border-b border-antracite/10 bg-crema px-6 py-4 shadow-lg"
        >
          <nav aria-label="Mobile" class="flex flex-col gap-1">
            {
              nav.map((item) => (
                <a
                  href={bestPath(item.key, locale)}
                  class="rounded-lg px-2 py-2.5 text-base text-antracite transition hover:bg-avorio"
                >
                  {item.label}
                </a>
              ))
            }
            <a
              href={bookHref}
              class="mt-2 rounded-full bg-terracotta px-5 py-3 text-center font-medium text-white"
            >
              {t("cta.check_availability")}
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>
