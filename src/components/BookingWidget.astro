const L = LABELS[locale] ?? LABELS.en!;
---

<section id="book" class="scroll-mt-20 py-16 lg:py-24">
  <div class="mx-auto max-w-4xl px-6 text-center">
    {title && <h2 class="font-display text-3xl text-antracite lg:text-4xl">{title}</h2>}
    {subtitle && <p class="mt-3 text-grigio">{subtitle}</p>}
    <p class="mt-4 text-sm text-grigio">
      <strong class="text-antracite">{SITE.rating.airbnb}/5</strong> su Airbnb ·
      {SITE.rating.airbnbCount} recensioni · Superhost
    </p>

    <div class="mt-8 text-left" data-evt-view="booking_widget_view">
      <div
        id="lodgify-search-bar"
        data-website-id={SITE.lodgify.websiteId}
        data-language-code={lang}
        data-checkout-page-url={checkoutUrl}
        data-dates-check-in-label={L.checkIn}
        data-dates-check-out-label={L.checkOut}
        data-guests-counter-label={L.guestsCounter}
        data-guests-input-singular-label={L.guestsSingular}
        data-guests-input-plural-label={L.guestsPlural}
        data-location-input-label={L.location}
        data-search-button-label={L.search}
        data-dates-input-min-stay-tooltip-text={L.minStay}
        data-guests-breakdown-label={L.guestsBreakdown}
        data-adults-label={L.adults}
        data-adults-description={L.adultsDesc}
        data-children-label={L.children}
        data-children-description={L.childrenDesc}
        data-children-not-allowed-label={L.childrenNo}
        data-infants-label={L.infants}
        data-infants-description={L.infantsDesc}
        data-infants-not-allowed-label={L.infantsNo}
        data-pets-label={L.pets}
        data-pets-not-allowed-label={L.petsNo}
        data-done-label={L.done}
        data-new-tab="true"
        data-version="stable"
        data-has-guests-breakdown
      >
      </div>
    </div>
  </div>
</section>

{/* L'inizializzazione del widget Lodgify è centralizzata nel Layout
    (gestisce View Transitions e prima visita). */}
