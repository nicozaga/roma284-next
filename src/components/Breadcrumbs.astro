---
interface Crumb {
  name: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-grigio">
  <ol class="flex flex-wrap items-center gap-1.5">
    {
      items.map((c, i) => (
        <li class="flex items-center gap-1.5">
          {c.href && i < items.length - 1 ? (
            <a href={c.href} class="hover:text-terracotta">{c.name}</a>
          ) : (
            <span class="text-antracite" aria-current="page">{c.name}</span>
          )}
          {i < items.length - 1 && <span class="text-antracite/30">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
