---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  /** Sfondo alternato. */
  variant?: "crema" | "avorio" | "salvia";
  narrow?: boolean;
}
const { id, eyebrow, title, variant = "crema", narrow = false } = Astro.props;
const bg = variant === "avorio" ? "bg-avorio" : variant === "salvia" ? "bg-salvia/10" : "bg-crema";
---

<section id={id} class:list={[bg, "scroll-mt-20 py-14 lg:py-20"]}>
  <div class:list={["mx-auto px-6", narrow ? "max-w-3xl" : "max-w-(--breakpoint-xl)"]}>
    {
      eyebrow && (
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-terracotta">{eyebrow}</p>
      )
    }
    {title && <h2 class="mt-2 font-display text-3xl text-antracite lg:text-4xl">{title}</h2>}
    <div class:list={[(eyebrow || title) && "mt-6"]}>
      <slot />
    </div>
  </div>
</section>
