---
import { CONNECTIONS, POI, pick } from "@data/content";
import type { Locale } from "@i18n/config";
import { SITE } from "@lib/site";
import Icon from "../Icon.astro";

interface Props {
  ctaHref: string;
  ctaLabel: string;
  locale?: Locale;
}
const { ctaHref, ctaLabel, locale = "it" } = Astro.props;
const connections = pick(CONNECTIONS, locale);
const poi = pick(POI, locale);
const T = {
  it: { eyebrow: "Posizione strategica", h2: "Nel centro di Piacenza, a un passo da Milano", intro: "Roma284 si trova in Via Roma 284, nel cuore del centro storico di Piacenza. La Frecciarossa porta a Milano Centrale in 33 minuti e tutto il centro è raggiungibile a piedi.", walk: "A piedi raggiungi:", load: "Carica la mappa" },
  en: { eyebrow: "Prime location", h2: "In central Piacenza, a step from Milan", intro: "Roma284 is on Via Roma 284, in the heart of Piacenza's historic centre. The Frecciarossa reaches Milan Centrale in 33 minutes and the whole centre is walkable.", walk: "On foot you reach:", load: "Load the map" },
}[locale as "it" | "en"] ?? { eyebrow: "", h2: "", intro: "", walk: "", load: "" };
const { lat, lng } = SITE.geo;
const bbox = `${lng - 0.006},${lat - 0.004},${lng + 0.006},${lat + 0.004}`;
const osmSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${lat},${lng}`;
---

<section class="mx-auto max-w-(--breakpoint-xl) px-6 py-16 lg:py-24">
  <div class="grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-16">
    <div data-reveal>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-terracotta">
        {T.eyebrow}
      </p>
      <h2 class="mt-3 font-display text-3xl text-antracite lg:text-4xl">
        {T.h2}
      </h2>
      <p class="mt-5 leading-relaxed text-grigio">
        {T.intro}
      </p>

      <dl class="mt-6 divide-y divide-antracite/8 border-y border-antracite/8">
        {
          connections.map((c) => (
            <div class="flex items-baseline justify-between gap-4 py-3">
              <dt class="text-antracite">
                {c.from}
                <span class="ml-2 text-sm text-grigio">{c.mode}</span>
              </dt>
              <dd class="font-display text-lg font-medium text-terracotta">
                {c.time}
              </dd>
            </div>
          ))
        }
      </dl>

      <div class="mt-6">
        <p class="text-sm font-semibold text-antracite">{T.walk}</p>
        <ul class="mt-2 flex flex-wrap gap-2 text-sm text-grigio">
          {
            poi.map((p) => (
              <li class="flex items-center gap-1.5 rounded-full bg-avorio px-3 py-1.5">
                <Icon name="pin" class="size-3.5 text-salvia" />
                {p}
              </li>
            ))
          }
        </ul>
      </div>

      <a
        href={ctaHref}
        class="mt-8 inline-flex items-center gap-2 font-medium text-terracotta transition hover:gap-3 hover:text-terracotta-dark"
      >
        {ctaLabel}
        <Icon name="arrow" class="size-4" />
      </a>
    </div>

    {/* Mappa click-to-load — l'iframe NON viene caricato finché non si clicca */}
    <div
      data-reveal
      class="relative aspect-4/3 overflow-hidden rounded-2xl border border-antracite/10 bg-avorio"
    >
      <button
        type="button"
        id="map-load"
        class="group absolute inset-0 flex flex-col items-center justify-center gap-3 bg-salvia/10 text-antracite transition hover:bg-salvia/20"
      >
        <span
          class="flex size-14 items-center justify-center rounded-full bg-white text-terracotta shadow-md transition group-hover:scale-105"
        >
          <Icon name="pin" class="size-7" />
        </span>
        <span class="font-medium">{T.load}</span>
        <span class="text-sm text-grigio">Via Roma 284, Piacenza</span>
      </button>
    </div>
  </div>
</section>

<script is:inline define:vars={{ osmSrc }}>
  const btn = document.getElementById("map-load");
  btn?.addEventListener("click", () => {
    const iframe = document.createElement("iframe");
    iframe.src = osmSrc;
    iframe.title = "Mappa di Roma284 — Via Roma 284, Piacenza";
    iframe.loading = "lazy";
    iframe.className = "absolute inset-0 size-full border-0";
    btn.replaceWith(iframe);
  });
</script>
