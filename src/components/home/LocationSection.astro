---
import { CONNECTIONS, POI, pick } from "@data/content";
import type { Locale } from "@i18n/config";
import { SITE } from "@lib/site";
import Icon from "../Icon.astro";

interface Props {
  ctaHref: string;
  ctaLabel: string;
  locale?: Locale;
}
const { ctaHref, ctaLabel, locale = "it" } = Astro.props;
const connections = pick(CONNECTIONS, locale);
const poi = pick(POI, locale);
const TMAP = {
  it: { eyebrow: "Posizione strategica", h2: "Nel centro di Piacenza, a un passo da Milano", intro: "Roma284 si trova in Via Roma 284, nel cuore del centro storico di Piacenza. La Frecciarossa porta a Milano Centrale in 33 minuti e tutto il centro è raggiungibile a piedi.", walk: "A piedi raggiungi:", load: "Carica la mappa" },
  en: { eyebrow: "Prime location", h2: "In central Piacenza, a step from Milan", intro: "Roma284 is on Via Roma 284, in the heart of Piacenza's historic centre. The Frecciarossa reaches Milan Centrale in 33 minutes and the whole centre is walkable.", walk: "On foot you reach:", load: "Load the map" },
  fr: { eyebrow: "Emplacement stratégique", h2: "Au centre de Plaisance, à un pas de Milan", intro: "Roma284 se trouve au Via Roma 284, au cœur du centre historique de Plaisance. La Frecciarossa rejoint Milan Centrale en 33 minutes et tout le centre est accessible à pied.", walk: "À pied, vous rejoignez :", load: "Charger la carte" },
  de: { eyebrow: "Strategische Lage", h2: "Im Zentrum von Piacenza, einen Schritt von Mailand entfernt", intro: "Roma284 liegt in der Via Roma 284, im Herzen des historischen Zentrums von Piacenza. Der Frecciarossa erreicht Mailand Centrale in 33 Minuten und das gesamte Zentrum ist zu Fuß erreichbar.", walk: "Zu Fuß erreichen Sie:", load: "Karte laden" },
  es: { eyebrow: "Ubicación estratégica", h2: "En el centro de Piacenza, a un paso de Milán", intro: "Roma284 se encuentra en Via Roma 284, en el corazón del centro histórico de Piacenza. El Frecciarossa llega a Milán Centrale en 33 minutos y todo el centro es accesible a pie.", walk: "A pie llegas a:", load: "Cargar el mapa" },
  pt: { eyebrow: "Localização estratégica", h2: "No centro de Piacenza, a um passo de Milão", intro: "O Roma284 fica na Via Roma 284, no coração do centro histórico de Piacenza. O Frecciarossa chega a Milão Centrale em 33 minutos e todo o centro é acessível a pé.", walk: "A pé chega a:", load: "Carregar o mapa" },
  nl: { eyebrow: "Strategische ligging", h2: "In het centrum van Piacenza, op een stap van Milaan", intro: "Roma284 ligt aan de Via Roma 284, in het hart van het historische centrum van Piacenza. De Frecciarossa bereikt Milaan Centrale in 33 minuten en het hele centrum is te voet bereikbaar.", walk: "Te voet bereik je:", load: "Kaart laden" },
  pl: { eyebrow: "Strategiczna lokalizacja", h2: "W centrum Piacenzy, o krok od Mediolanu", intro: "Roma284 znajduje się przy Via Roma 284, w sercu historycznego centrum Piacenzy. Frecciarossa dociera do Mediolanu Centrale w 33 minuty, a całe centrum jest osiągalne pieszo.", walk: "Pieszo dotrzesz do:", load: "Załaduj mapę" },
  sv: { eyebrow: "Strategiskt läge", h2: "I centrala Piacenza, ett stenkast från Milano", intro: "Roma284 ligger på Via Roma 284, i hjärtat av Piacenzas historiska centrum. Frecciarossa når Milano Centrale på 33 minuter och hela centrum nås till fots.", walk: "Till fots når du:", load: "Ladda kartan" },
};
const T = TMAP[locale as keyof typeof TMAP] ?? { eyebrow: "", h2: "", intro: "", walk: "", load: "" };
// Mappa caricata per indirizzo (geocoding di Google): il pin punta sempre al
// civico corretto senza dipendere da coordinate scritte a mano.
const mapQuery = "Via Roma 284, 29121 Piacenza, Italia";
const osmSrc = `https://maps.google.com/maps?q=${encodeURIComponent(mapQuery)}&z=16&output=embed`;
---

<section class="mx-auto max-w-(--breakpoint-xl) px-6 py-16 lg:py-24">
  <div class="grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-16">
    <div data-reveal>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-terracotta">
        {T.eyebrow}
      </p>
      <h2 class="mt-3 font-display text-3xl text-antracite lg:text-4xl">
        {T.h2}
      </h2>
      <p class="mt-5 leading-relaxed text-grigio">
        {T.intro}
      </p>

      <dl class="mt-6 divide-y divide-antracite/8 border-y border-antracite/8">
        {
          connections.map((c) => (
            <div class="flex items-baseline justify-between gap-4 py-3">
              <dt class="text-antracite">
                {c.from}
                <span class="ml-2 text-sm text-grigio">{c.mode}</span>
              </dt>
              <dd class="font-display text-lg font-medium text-terracotta">
                {c.time}
              </dd>
            </div>
          ))
        }
      </dl>

      <div class="mt-6">
        <p class="text-sm font-semibold text-antracite">{T.walk}</p>
        <ul class="mt-2 flex flex-wrap gap-2 text-sm text-grigio">
          {
            poi.map((p) => (
              <li class="flex items-center gap-1.5 rounded-full bg-avorio px-3 py-1.5">
                <Icon name="pin" class="size-3.5 text-salvia" />
                {p}
              </li>
            ))
          }
        </ul>
      </div>

      <a
        href={ctaHref}
        class="mt-8 inline-flex items-center gap-2 font-medium text-terracotta transition hover:gap-3 hover:text-terracotta-dark"
      >
        {ctaLabel}
        <Icon name="arrow" class="size-4" />
      </a>
    </div>

    {/* Mappa caricata direttamente: l'iframe è lazy, parte appena la sezione entra in viewport */}
    <div
      data-reveal
      class="relative aspect-4/3 overflow-hidden rounded-2xl border border-antracite/10 bg-avorio"
    >
      <iframe
        src={osmSrc}
        title="Mappa di Roma284 — Via Roma 284, Piacenza"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="absolute inset-0 size-full border-0"
      ></iframe>
    </div>
  </div>
</section>
