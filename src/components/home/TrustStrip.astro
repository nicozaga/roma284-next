---
import { SITE } from "@lib/site";
import Icon from "../Icon.astro";
---

<section aria-label="Valutazioni" class="border-y border-antracite/8 bg-avorio">
  <div
    class="mx-auto flex max-w-(--breakpoint-xl) flex-wrap items-center justify-center gap-x-8 gap-y-3 px-6 py-5 text-sm text-grigio"
  >
    <span class="flex items-center gap-1.5">
      <span class="flex text-terracotta">
        <Icon name="star" class="size-4 fill-terracotta" />
        <Icon name="star" class="size-4 fill-terracotta" />
        <Icon name="star" class="size-4 fill-terracotta" />
        <Icon name="star" class="size-4 fill-terracotta" />
        <Icon name="star" class="size-4 fill-terracotta" />
      </span>
      <strong class="text-antracite">{SITE.rating.airbnb}/5</strong> su Airbnb
    </span>
    <span class="hidden h-4 w-px bg-antracite/15 sm:block"></span>
    <span><strong class="text-antracite">{SITE.rating.booking}/10</strong> su Booking</span>
    <span class="hidden h-4 w-px bg-antracite/15 sm:block"></span>
    <span><strong class="text-antracite">{SITE.rating.airbnbCount}</strong> recensioni verificate</span>
    <span class="hidden h-4 w-px bg-antracite/15 sm:block"></span>
    <span>Superhost · risposta {SITE.host.responseTime}</span>
  </div>
</section>
