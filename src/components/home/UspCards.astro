---
import Icon from "../Icon.astro";
import { USP, pick } from "@data/content";
import type { Locale } from "@i18n/config";

interface Props { locale?: Locale }
const { locale = "it" } = Astro.props;
const items = pick(USP, locale);
---

<section class="mx-auto max-w-(--breakpoint-xl) px-6 py-16 lg:py-20">
  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {
      items.map((u) => (
        <article
          data-reveal
          class="rounded-2xl border border-antracite/8 bg-white p-6 transition hover:-translate-y-1 hover:border-terracotta/30 hover:shadow-lg hover:shadow-black/5"
        >
          <span class="flex size-11 items-center justify-center rounded-full bg-avorio text-terracotta">
            <Icon name={u.icon as any} class="size-6" />
          </span>
          <h3 class="mt-4 text-lg text-antracite">{u.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-grigio">{u.text}</p>
        </article>
      ))
    }
  </div>
</section>
