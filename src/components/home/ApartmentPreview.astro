---
import { APARTMENT_INTRO_IT } from "@data/content";
import { AMENITIES_IT } from "@data/amenities";
import { SITE } from "@lib/site";
import Icon from "../Icon.astro";

interface Props {
  detailsHref: string;
  ctaLabel: string;
}
const { detailsHref, ctaLabel } = Astro.props;

const specs = [
  `${SITE.stay.sizeSqm} m²`,
  "1 camera + soggiorno",
  "1 bagno",
  `fino a ${SITE.stay.maxGuests} ospiti`,
];
---

<section id="apartment" class="scroll-mt-20 bg-crema py-16 lg:py-24">
  <div
    class="mx-auto grid max-w-(--breakpoint-xl) gap-12 px-6 lg:grid-cols-2 lg:gap-16"
  >
    <div data-reveal>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-terracotta">
        L'appartamento
      </p>
      <h2 class="mt-3 font-display text-3xl text-antracite lg:text-4xl">
        Comfort moderni, anima storica
      </h2>
      <p class="mt-5 leading-relaxed text-grigio">{APARTMENT_INTRO_IT}</p>

      <ul class="mt-6 flex flex-wrap gap-2">
        {
          specs.map((s) => (
            <li class="rounded-full bg-avorio px-3.5 py-1.5 text-sm text-antracite">
              {s}
            </li>
          ))
        }
      </ul>

      <a
        href={detailsHref}
        class="mt-8 inline-flex items-center gap-2 font-medium text-terracotta transition hover:gap-3 hover:text-terracotta-dark"
      >
        {ctaLabel}
        <Icon name="arrow" class="size-4" />
      </a>
    </div>

    <div data-reveal class="grid gap-6 sm:grid-cols-2">
      {
        AMENITIES_IT.map((group) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-antracite">
              {group.title}
            </h3>
            <ul class="mt-2.5 space-y-1.5 text-sm text-grigio">
              {group.items.map((item) => (
                <li class="flex items-start gap-2">
                  <Icon name="check" class="mt-0.5 size-4 shrink-0 text-salvia" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
