---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { GALLERY_ALT } from "@data/gallery";
import { pick } from "@data/content";
import type { Locale } from "@i18n/config";

interface Props {
  title: string;
  subtitle?: string;
  locale?: Locale;
}
const { title, subtitle, locale = "it" } = Astro.props;
const ALT = pick(GALLERY_ALT, locale);

const modules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/gallery/*.jpg",
  { eager: true },
);
const sorted = Object.entries(modules)
  .map(([path, mod]) => {
    const num = path.match(/\/(\d+)\.jpg$/)?.[1];
    return num ? { num, src: mod.default } : null;
  })
  .filter((x): x is { num: string; src: ImageMetadata } => x !== null)
  .sort((a, b) => Number(a.num) - Number(b.num));

// Versione grande ottimizzata per la lightbox.
const photos = await Promise.all(
  sorted.map(async ({ num, src }) => {
    const full = await getImage({ src, format: "avif" });
    return { num, src, full: full.src, caption: ALT[num] ?? "Roma284" };
  }),
);

const ui =
  locale === "en"
    ? { prev: "Previous photo", next: "Next photo", close: "Close", of: "of", open: "Open photo" }
    : { prev: "Foto precedente", next: "Foto successiva", close: "Chiudi", of: "di", open: "Apri la foto" };
---

<section aria-label={title} class="mx-auto max-w-(--breakpoint-xl) px-6 py-12 lg:py-16">
  <h2 class="font-display text-3xl text-antracite lg:text-4xl">{title}</h2>
  {subtitle && <p class="mt-2 max-w-2xl text-grigio">{subtitle}</p>}

  <div
    data-gallery
    class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4 lg:gap-4"
  >
    {
      photos.map(({ num, src, full, caption }, i) => (
        <button
          type="button"
          data-gallery-item
          data-full={full}
          data-caption={caption}
          aria-label={ui.open}
          class:list={[
            "group relative block aspect-[4/3] overflow-hidden rounded-2xl bg-avorio focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-terracotta",
            i === 0 && "col-span-2 sm:col-span-2 lg:col-span-2 lg:row-span-2 lg:aspect-auto",
          ]}
        >
          <Image
            src={src}
            alt={caption}
            widths={[400, 800]}
            sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
            format="avif"
            loading="lazy"
            class="size-full object-cover transition duration-500 group-hover:scale-105"
          />
          <span class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-antracite/55 to-transparent p-3 pt-8 text-left text-xs text-white opacity-0 transition group-hover:opacity-100">
            {caption}
          </span>
        </button>
      ))
    }
  </div>

  {/* Lightbox navigabile */}
  <div data-lightbox class="r284-lb" aria-hidden="true" role="dialog" aria-modal="true">
    <button data-lb-close class="r284-lb__close" aria-label={ui.close}>
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
    </button>
    <button data-lb-prev class="r284-lb__nav r284-lb__prev" aria-label={ui.prev}>
      <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <figure class="r284-lb__fig">
      <img data-lb-img alt="" class="r284-lb__img" />
      <figcaption class="r284-lb__cap">
        <span data-lb-cap></span>
        <span data-lb-count class="r284-lb__count"></span>
      </figcaption>
    </figure>
    <button data-lb-next class="r284-lb__nav r284-lb__next" aria-label={ui.next}>
      <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>
</section>

<style>
  .r284-lb {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgb(20 20 20 / 0.92);
    backdrop-filter: blur(6px);
  }
  .r284-lb.is-open { display: flex; }
  .r284-lb__fig { margin: 0; max-width: min(100%, 1100px); }
  .r284-lb__img {
    display: block;
    max-height: 82vh;
    max-width: 100%;
    width: auto;
    margin: 0 auto;
    border-radius: 0.75rem;
    object-fit: contain;
  }
  .r284-lb__cap {
    margin-top: 0.75rem;
    text-align: center;
    color: #faf5ee;
    font-size: 0.85rem;
  }
  .r284-lb__count { display: block; opacity: 0.6; margin-top: 0.15rem; }
  .r284-lb__close {
    position: absolute;
    top: 1rem;
    right: 1.1rem;
    color: #faf5ee;
    padding: 0.4rem;
  }
  .r284-lb__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    color: #1a1a1a;
    background: rgb(255 255 255 / 0.85);
    transition: background 0.2s;
  }
  .r284-lb__nav:hover { background: #fff; }
  .r284-lb__prev { left: 0.75rem; }
  .r284-lb__next { right: 0.75rem; }
  @media (min-width: 1024px) {
    .r284-lb__prev { left: 1.5rem; }
    .r284-lb__next { right: 1.5rem; }
  }
</style>

<script is:inline define:vars={{ ui }}>
  function initGallery() {
    document.querySelectorAll("[data-gallery]").forEach((root) => {
      if (root.dataset.galInit) return;
      root.dataset.galInit = "1";
      const items = Array.from(root.querySelectorAll("[data-gallery-item]"));
      const lb = root.querySelector("[data-lightbox]");
      const img = lb.querySelector("[data-lb-img]");
      const cap = lb.querySelector("[data-lb-cap]");
      const count = lb.querySelector("[data-lb-count]");
      const data = items.map((b) => ({ full: b.dataset.full, cap: b.dataset.caption }));
      let idx = 0;
      const show = (i) => {
        idx = (i + data.length) % data.length;
        img.src = data[idx].full;
        img.alt = data[idx].cap;
        cap.textContent = data[idx].cap;
        count.textContent = idx + 1 + " " + ui.of + " " + data.length;
      };
      const open = (i) => { show(i); lb.classList.add("is-open"); lb.setAttribute("aria-hidden", "false"); document.body.style.overflow = "hidden"; };
      const close = () => { lb.classList.remove("is-open"); lb.setAttribute("aria-hidden", "true"); document.body.style.overflow = ""; };
      items.forEach((b, i) => b.addEventListener("click", () => open(i)));
      lb.querySelector("[data-lb-next]").addEventListener("click", (e) => { e.stopPropagation(); show(idx + 1); });
      lb.querySelector("[data-lb-prev]").addEventListener("click", (e) => { e.stopPropagation(); show(idx - 1); });
      lb.querySelector("[data-lb-close]").addEventListener("click", close);
      lb.addEventListener("click", (e) => { if (e.target === lb) close(); });
      lb.addEventListener("keydown", (e) => {
        if (e.key === "Escape") close();
        else if (e.key === "ArrowRight") show(idx + 1);
        else if (e.key === "ArrowLeft") show(idx - 1);
      });
      document.addEventListener("keydown", (e) => {
        if (!lb.classList.contains("is-open")) return;
        if (e.key === "Escape") close();
        else if (e.key === "ArrowRight") show(idx + 1);
        else if (e.key === "ArrowLeft") show(idx - 1);
      });
      let sx = 0;
      lb.addEventListener("touchstart", (e) => { sx = e.changedTouches[0].clientX; }, { passive: true });
      lb.addEventListener("touchend", (e) => { const dx = e.changedTouches[0].clientX - sx; if (Math.abs(dx) > 40) show(idx + (dx < 0 ? 1 : -1)); }, { passive: true });
    });
  }
  initGallery();
  document.addEventListener("astro:after-swap", initGallery);
</script>
